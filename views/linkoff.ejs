<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>الرابط غير متاح</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#0f0f17;font-family:'Segoe UI',Arial,sans-serif;color:#fff}
.card{background:#1a1a2e;border:1px solid #2a2a4a;border-radius:24px;padding:48px 36px;max-width:420px;width:92%;text-align:center;box-shadow:0 8px 48px rgba(0,0,0,.5)}
.icon{font-size:72px;margin-bottom:20px;display:block}
h1{font-size:22px;font-weight:700;color:#e0e0ff;margin-bottom:12px}
p{color:#888;font-size:15px;line-height:1.7;margin-bottom:28px}
.badge{display:inline-block;background:#2a0a0a;border:1px solid #8b0000;border-radius:50px;padding:8px 20px;font-size:13px;color:#ff6b6b;margin-bottom:24px}
a{display:inline-block;background:linear-gradient(135deg,#5865f2,#3b4bc8);color:#fff;text-decoration:none;padding:14px 32px;border-radius:50px;font-size:15px;font-weight:600;transition:.2s}
a:hover{transform:translateY(-2px);box-shadow:0 4px 20px rgba(88,101,242,.4)}
</style>
</head>
<body>
<div class="card">
  <%
  const icons   = { disabled:'🔒', expired:'⌛', maxed:'🔢', not_found:'🔍' };
  const titles  = { disabled:'الرابط معطّل', expired:'انتهت صلاحية الرابط', maxed:'وصل الرابط للحد الأقصى', not_found:'الرابط غير موجود' };
  const descs   = {
    disabled:  'هذا الرابط تم تعطيله من قِبل منشئه.',
    expired:   'انتهت صلاحية هذا الرابط ولم يعد متاحاً.',
    maxed:     'تجاوز هذا الرابط الحد الأقصى من الزيارات المسموح بها.',
    not_found: 'لم نتمكن من إيجاد الرابط المطلوب.',
  };
  const r = reason || 'not_found';
  %>
  <span class="icon"><%- icons[r] || '🔗' %></span>
  <div class="badge"><%- r.toUpperCase() %></div>
  <h1><%- titles[r] || 'الرابط غير متاح' %></h1>
  <p><%- descs[r] || 'هذا الرابط غير متاح حالياً.' %></p>
  <a href="https://www.google.com">العودة للرئيسية</a>
</div>
</body>
</html>
