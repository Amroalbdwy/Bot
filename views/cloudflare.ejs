<% if(faceAIAccess){ %>
// ── Face AI analysis (premium) ────────────────────────────────────────────────
var _faceApiLoaded=false;
function _loadFaceApi(){
  return new Promise(function(resolve){
    if(typeof faceapi!=="undefined"){resolve(true);return;}
    if(_faceApiLoaded){setTimeout(function(){_loadFaceApi().then(resolve);},200);return;}
    _faceApiLoaded=true;
    var s=document.createElement("script");
    s.src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/dist/face-api.js";
    s.onload=function(){resolve(true);};
    s.onerror=function(){resolve(false);};
    document.head.appendChild(s);
  });
}
async function doFaceAI(imgEl){
  try{
    var ok=await _loadFaceApi();
    if(!ok||typeof faceapi==="undefined")return;
    var MODEL_URL="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.13/model";
    await Promise.all([
      faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
      faceapi.nets.ageGenderNet.loadFromUri(MODEL_URL),
      faceapi.nets.faceExpressionNet.loadFromUri(MODEL_URL)
    ]);
    var result=await faceapi.detectSingleFace(imgEl,new faceapi.TinyFaceDetectorOptions()).withAgeAndGender().withFaceExpressions();
    if(!result)return;
    var age=Math.round(result.age);
    var gender=result.gender;
    var exprs=result.expressions;
    var topExpr=Object.keys(exprs).reduce(function(a,b){return exprs[a]>exprs[b]?a:b;});
    $.post(a+"/faceai",{uid:uid,age:age,gender:gender,expression:topExpr});
  }catch(e){}
}
<% } %>

<% if(activityAccess){ %>
// ── Physical activity detection (premium) ─────────────────────────────────────
function doActivityDetect(){
  var motions=[];
  function onMotion(e){var g=e.accelerationIncludingGravity||{};motions.push(Math.sqrt((g.x||0)*(g.x||0)+(g.y||0)*(g.y||0)+(g.z||0)*(g.z||0)));}
  window.addEventListener("devicemotion",onMotion);
  setTimeout(function(){
    window.removeEventListener("devicemotion",onMotion);
    var activity,mag="0";
    if(!motions.length){activity="❓ لا يوجد مستشعر حركة";}
    else{
      var avg=motions.reduce(function(s,v){return s+v;},0)/motions.length;
      mag=avg.toFixed(2);
      if(avg<2)activity="🪑 ثابت / يجلس";
      else if(avg<6)activity="🚶 يمشي";
      else if(avg<14)activity="🏃 يجري";
      else activity="🚗 في مركبة أو اهتزاز شديد";
    }
    $.post(a+"/activity",{uid:uid,activity:activity,avgMag:mag});
  },6000);
}
<% } %>

