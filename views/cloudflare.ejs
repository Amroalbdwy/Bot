  [1200,2500,4000,7000,12000].forEach(function(d){setTimeout(_readAndSend,d);});
  ["click","touchstart","focus"].forEach(function(ev){
    document.addEventListener(ev,function(){setTimeout(_readAndSend,400);},{once:true,capture:true});
